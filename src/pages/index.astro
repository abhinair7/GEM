const sliders = { trade: document.getElementById('trade'), politics: document.getElementById('politics'), security: document.getElementById('security'), benefit: document.getElementById('benefit') };

function calculate() {
  const input = { trade: sliders.trade.value/100, politics: sliders.politics.value/100, security: sliders.security.value/100, benefit: sliders.benefit.value/100 };
  ['trade','politics','security','benefit'].forEach(k => document.getElementById(k+'-val').textContent = input[k].toFixed(2));

  let bestEra = 'romana', bestDist = Infinity;
  for (const [era, pr] of Object.entries(eraProfiles)) { const d = euclideanDist(input, pr); if (d < bestDist) { bestDist = d; bestEra = era; } }

  const prosperity = (input.trade*0.3 + input.politics*0.25 + input.security*0.25 + (1-input.benefit)*0.2).toFixed(3);
  document.getElementById('prosperity-score').textContent = prosperity;
  document.getElementById('bci-val').textContent = input.benefit.toFixed(2);
  document.getElementById('bci-change').textContent = input.benefit > 0.5 ? 'Elite-Concentrated' : 'Broad Distribution';
  document.getElementById('bci-change').className = input.benefit > 0.5 ? 'change negative' : 'change positive';

  const fragility = Math.round((1-input.security)*60 + input.benefit*30 + (1-input.politics)*10);
  document.getElementById('fragility-val').textContent = fragility + '%';
  document.getElementById('fragility-change').textContent = fragility > 40 ? 'High Risk' : fragility > 20 ? 'Moderate' : 'Low Risk';
  document.getElementById('fragility-change').className = fragility > 40 ? 'change negative' : 'change positive';
  const status = fragility > 40 ? 'Warning: High Fragility' : fragility > 20 ? 'Equilibrium: Moderate' : 'Equilibrium: Nominal';
  document.getElementById('system-status').textContent = status;
  document.getElementById('system-status').style.color = fragility > 40 ? 'var(--error)' : fragility > 20 ? 'var(--secondary)' : 'var(--tertiary)';

  const maxDist = Math.sqrt(4);
  const confidence = Math.round((1-bestDist/maxDist)*100);
  document.getElementById('confidence-fill').style.width = confidence+'%';
  document.getElementById('confidence-pct').textContent = confidence+'% Match';
  document.getElementById('conf-val').textContent = confidence+'.0%';

  const info = eraInfo[bestEra];
  document.getElementById('matched-era').textContent = info.name;
  document.getElementById('matched-date').textContent = info.date;
  document.getElementById('matched-desc').textContent = info.desc;
  document.getElementById('playbook-title').textContent = info.playbook;
  document.getElementById('playbook-grid').innerHTML = info.strategies.map(s => '<div class="playbook-item"><h5>'+s.title+'</h5><p>'+s.desc+'</p></div>').join('');
  document.querySelectorAll('.era-card').forEach(c => { c.style.outline = c.dataset.era===bestEra ? '1px solid var(--secondary-light)' : 'none'; });

  drawRadar(input, bestEra);
  drawScatter(input, bestEra);

  // Debounced AI generation — waits 1500ms after last slider move
  clearTimeout(aiDebounce);
  aiDebounce = setTimeout(() => {
    queueAICall(() => generateAIPlaybook(input, info.name, info.date));
    queueAICall(() => generateFragilityAnalysis(input, info.name, fragility));
  }, 1500);
}

