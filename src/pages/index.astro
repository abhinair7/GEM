// News feed: fetch GDELT directly from client (no CORS issues, avoids Vercel 10s timeout)
var GDELT_KEYWORDS = ['iran','tehran','persian','hormuz','irgc','sanction','nuclear','missile','military',
  'oil','crude','opec','gulf','middle east','hezbollah','houthi','israel','drone','weapon',
  'diplomacy','diplomat','conflict','escalat','ceasefire','war','attack','defense','uranium'];

function isRelevantTitle(title) {
  var t = title.toLowerCase();
  return GDELT_KEYWORDS.some(function(kw) { return t.indexOf(kw) >= 0; });
}

function fetchGNews() {
  document.getElementById('feed-source-tag').textContent = '⟳ Fetching live intel…';
  var newsUrl = '/api/news?t=' + Date.now();
  fetch(newsUrl)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var articles = (data.articles || []).slice(0, 8);
      if (articles.length >= 2) {
        document.getElementById('feed-source-tag').textContent = 'GDELT API — LIVE';
        dripArticles(articles);
      } else {
        console.log('Insufficient GDELT articles — using simulated feed');
        document.getElementById('feed-source-tag').textContent = 'SIMULATED SCENARIO';
        loadFallback();
      }
    })
    .catch(function(err) {
      console.error('News fetch error:', err);
      document.getElementById('feed-source-tag').textContent = 'SIMULATED SCENARIO';
      loadFallback();
    });
}

// Drip-feed live articles one by one
const collectedHeadlines = [];
function dripArticles(articles) {
  let idx = 0;
  function drip() {
    if (idx >= articles.length) {
      // All articles loaded — trigger AI briefing
      if (collectedHeadlines.length >= 3) queueAICall(() => generateBriefing(collectedHeadlines));
      return;
    }
    const art = articles[idx];
    let time = 'LIVE';
    if (art.time) {
      const d = new Date(art.time);
      if (!isNaN(d)) time = String(d.getUTCHours()).padStart(2,'0') + ':' + String(d.getUTCMinutes()).padStart(2,'0') + ' UTC';
      else if (art.time.length >= 13) time = art.time.substring(9,11) + ':' + art.time.substring(11,13) + ' UTC';
    }
    collectedHeadlines.push(art.title);
    const impacts = classifyArticle(art.title);
    addFeedItem(time, art.title, art.desc, impacts, true, art.url);
    idx++;
    if (idx < articles.length) setTimeout(drip, 2500);
    else if (collectedHeadlines.length >= 3) queueAICall(() => generateBriefing(collectedHeadlines));
  }
  drip();
}

function loadFallback() {
  let idx = 0;
  function drip() {
    if (idx >= fallbackEvents.length) return;
    const ev = fallbackEvents[idx];
    addFeedItem(ev.time, ev.title, ev.desc, ev.impacts, false);
    idx++;
    if (idx < fallbackEvents.length) setTimeout(drip, 2200);
  }
  drip();
}

