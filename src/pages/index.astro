// =========================================================
// REAL DATA CHARTS — World Bank API + FRED
// =========================================================

// Smart X-axis tick generator — adapts labels to any date range
var _MO = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
function getXTicks(lo, hi) {
  var range = hi - lo, ticks = [], y, m, p;
  if (range > 4) {
    var step = range > 50 ? 10 : range > 25 ? 5 : 2;
    for (y = Math.ceil(lo / step) * step; y <= hi; y += step)
      ticks.push({ pos: y, label: String(y) });
  } else if (range > 1.5) {
    for (y = Math.floor(lo); y <= Math.ceil(hi); y++)
      for (m = 0; m < 12; m += 3) { p = y + m / 12; if (p >= lo - 0.05 && p <= hi + 0.05) ticks.push({ pos: p, label: _MO[m] + " '" + String(y % 100).padStart(2, '0') }); }
  } else if (range > 0.4) {
    for (y = Math.floor(lo); y <= Math.ceil(hi); y++)
      for (m = 0; m < 12; m++) { p = y + m / 12; if (p >= lo - 0.02 && p <= hi + 0.02) ticks.push({ pos: p, label: _MO[m] + " '" + String(y % 100).padStart(2, '0') }); }
  } else if (range > 0.15) {
    for (y = Math.floor(lo); y <= Math.ceil(hi); y++)
      for (m = 0; m < 12; m++) for (var h = 0; h < 2; h++) { p = y + (m + h * 0.5) / 12; if (p >= lo - 0.01 && p <= hi + 0.01) ticks.push({ pos: p, label: _MO[m] + ' ' + (h ? '15' : '1') }); }
  } else {
    for (y = Math.floor(lo); y <= Math.ceil(hi); y++)
      for (m = 0; m < 12; m++) for (var w = 0; w < 5; w++) { var d = w * 7 + 1; if (d > 28) continue; p = y + (m + (d - 1) / 30) / 12; if (p >= lo - 0.005 && p <= hi + 0.005) ticks.push({ pos: p, label: _MO[m] + ' ' + d }); }
  }
  return ticks;
}

// Draw x-axis labels with auto-thinning and rotation on narrow canvases
function drawXAxis(ctx, ticks, toX, W, H, pad) {
  var chartW = W - pad.left - pad.right;
  var isMobile = chartW < 350;
  // Estimate label width; thin ticks so they don't overlap
  var labelW = isMobile ? 32 : 52;
  var maxTicks = Math.max(2, Math.floor(chartW / labelW));
  var visible = ticks.filter(function(t) {
    var tx = toX(t.pos);
    return tx >= pad.left + 5 && tx <= W - pad.right - 5;
  });
  // Evenly thin to maxTicks
  if (visible.length > maxTicks) {
    var step = Math.ceil(visible.length / maxTicks);
    visible = visible.filter(function(_, i) { return i % step === 0; });
  }
  var angle = isMobile ? -Math.PI / 5 : 0;  // ~36° rotation on mobile
  visible.forEach(function(t) {
    var tx = toX(t.pos);
    // Grid line
    ctx.beginPath(); ctx.moveTo(tx, H - pad.bottom); ctx.lineTo(tx, pad.top);
    ctx.strokeStyle = 'rgba(0,0,0,0.03)'; ctx.lineWidth = 1; ctx.stroke();
    // Label
    ctx.fillStyle = '#a3a8a0';
    if (angle) {
      ctx.save();
      ctx.translate(tx, H - pad.bottom + 14);
      ctx.rotate(angle);
      ctx.textAlign = 'right';
      ctx.font = '400 8px Inter';
      ctx.fillText(t.label, 0, 0);
      ctx.restore();
    } else {
      ctx.textAlign = 'center';
      ctx.fillText(t.label, tx, H - pad.bottom + 16);
    }
  });
}

// =========================================================
// CHART TYPE 1: GROUPED BAR CHART (for GDP)
// =========================================================
function drawGroupedBar(canvasId, datasets, options = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  const ctx = canvas.getContext('2d');
  const W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  const pad = { top: 35, right: 130, bottom: 55, left: 70 };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);

  // Group data by decade
  const decades = {};
  datasets.forEach(ds => {
    ds.data.forEach(d => {
      const dec = Math.floor(d.year / 10) * 10;
      if (!decades[dec]) decades[dec] = {};
      if (!decades[dec][ds.label]) decades[dec][ds.label] = [];
      decades[dec][ds.label].push(d.value);
    });
  });
  const decadeKeys = Object.keys(decades).map(Number).sort((a,b)=>a-b);
  const decadeAvgs = decadeKeys.map(dec => {
    const obj = { decade: dec };
    datasets.forEach(ds => {
      const vals = decades[dec]?.[ds.label] || [];
      obj[ds.label] = vals.length ? vals.reduce((s,v)=>s+v,0)/vals.length : 0;
    });
    return obj;
  });

  let maxVal = 0;
  decadeAvgs.forEach(d => datasets.forEach(ds => { maxVal = Math.max(maxVal, d[ds.label] || 0); }));
  maxVal = maxVal * 1.1;

  // Y-axis grid
  const ySteps = 5;
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let i = 0; i <= ySteps; i++) {
    const v = (maxVal * i / ySteps);
    const y = H - pad.bottom - (v / maxVal) * ch;
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W-pad.right, y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    const label = options.yFormat ? options.yFormat(v) : v.toFixed(0);
    ctx.fillText(label, pad.left - 8, y + 3);
  }
  // Axes
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Event markers
  if (options.events) {
    options.events.forEach(ev => {
      const decIdx = decadeKeys.findIndex(d => d <= ev.year && d+10 > ev.year);
      if (decIdx >= 0) {
        const groupW = cw / decadeKeys.length;
        const x = pad.left + decIdx * groupW + groupW / 2;
        ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, H-pad.bottom);
        ctx.strokeStyle = 'rgba(196,68,45,0.2)'; ctx.setLineDash([3,3]); ctx.lineWidth = 1; ctx.stroke(); ctx.setLineDash([]);
        ctx.font = '500 7px Inter'; ctx.fillStyle = 'rgba(196,68,45,0.5)'; ctx.textAlign = 'center';
        ctx.fillText(ev.label, x, pad.top - 4);
      }
    });
  }

  // Draw bars
  const nGroups = decadeKeys.length;
  const nBars = datasets.length;
  const groupW = cw / nGroups;
  const barGap = 4;
  const barW = (groupW - barGap * (nBars + 1)) / nBars;
  decadeAvgs.forEach((d, gi) => {
    const gx = pad.left + gi * groupW;
    datasets.forEach((ds, bi) => {
      const val = d[ds.label] || 0;
      const barH = (val / maxVal) * ch;
      const x = gx + barGap * (bi + 1) + barW * bi;
      const y = H - pad.bottom - barH;
      // Bar with subtle gradient
      const grad = ctx.createLinearGradient(x, y, x, H - pad.bottom);
      grad.addColorStop(0, ds.color);
      grad.addColorStop(1, ds.color + '66');
      ctx.fillStyle = grad;
      // Rounded top corners
      const r = Math.min(3, barW / 4);
      ctx.beginPath();
      ctx.moveTo(x + r, y); ctx.lineTo(x + barW - r, y);
      ctx.quadraticCurveTo(x + barW, y, x + barW, y + r);
      ctx.lineTo(x + barW, H - pad.bottom); ctx.lineTo(x, H - pad.bottom);
      ctx.lineTo(x, y + r); ctx.quadraticCurveTo(x, y, x + r, y);
      ctx.closePath(); ctx.fill();
      // Value label on top
      if (barH > 20) {
        ctx.font = '600 8px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'center';
        const lbl = options.yFormat ? options.yFormat(val) : val.toFixed(0);
        ctx.fillText(lbl, x + barW/2, y - 5);
      }
    });
    // Decade label
    ctx.font = '500 10px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(d.decade + 's', gx + groupW/2, H - pad.bottom + 18);
  });

  // Legend
  let ly = pad.top + 10;
  datasets.forEach(ds => {
    ctx.fillStyle = ds.color;
    ctx.fillRect(W-pad.right+16, ly, 14, 14);
    ctx.font = '500 10px Inter'; ctx.fillStyle = '#44474e'; ctx.textAlign = 'left';
    ctx.fillText(ds.label, W-pad.right+36, ly+11);
    ly += 22;
  });

  // Y-axis label
  if (options.yLabel) {
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(options.yLabel, 0, 0); ctx.restore();
  }
}

// =========================================================
// CHART TYPE 2: SMOOTH AREA CHART (for Trade)
// =========================================================
function drawAreaChart(canvasId, datasets, options = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  const ctx = canvas.getContext('2d');
  const W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  const pad = { top: 35, right: 40, bottom: 55, left: 70 };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);

  let allYears = [], allVals = [];
  datasets.forEach(ds => ds.data.forEach(d => { allYears.push(d.year); allVals.push(d.value); }));
  const minYear = Math.min(...allYears), maxYear = Math.max(...allYears);
  const minVal = 0, maxVal = (options.maxVal || Math.max(...allVals)) * 1.1;
  const valRange = maxVal - minVal || 1;
  const yearRange = maxYear - minYear || 1;
  function toX(yr) { return pad.left + ((yr-minYear)/yearRange)*cw; }
  function toY(v) { return H - pad.bottom - ((v-minVal)/valRange)*ch; }

  // Grid
  const ySteps = 5;
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let i = 0; i <= ySteps; i++) {
    const v = minVal + (valRange*i/ySteps), y = toY(v);
    ctx.beginPath(); ctx.moveTo(pad.left,y); ctx.lineTo(W-pad.right,y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillText(options.yFormat ? options.yFormat(v) : v.toFixed(0), pad.left-8, y+3);
  }
  // X labels
  drawXAxis(ctx, getXTicks(minYear, maxYear), toX, W, H, pad);
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Draw filled areas (back to front so first dataset is on top)
  [...datasets].reverse().forEach(ds => {
    const sorted = ds.data.slice().sort((a,b)=>a.year-b.year);
    if (sorted.length < 2) return;
    // Filled area with gradient
    ctx.beginPath();
    sorted.forEach((d,i) => { i===0 ? ctx.moveTo(toX(d.year),toY(d.value)) : ctx.lineTo(toX(d.year),toY(d.value)); });
    ctx.lineTo(toX(sorted[sorted.length-1].year), H-pad.bottom);
    ctx.lineTo(toX(sorted[0].year), H-pad.bottom);
    ctx.closePath();
    const grad = ctx.createLinearGradient(0, pad.top, 0, H-pad.bottom);
    grad.addColorStop(0, ds.color + '30');
    grad.addColorStop(1, ds.color + '05');
    ctx.fillStyle = grad; ctx.fill();
    // Stroke
    ctx.beginPath();
    sorted.forEach((d,i) => { i===0 ? ctx.moveTo(toX(d.year),toY(d.value)) : ctx.lineTo(toX(d.year),toY(d.value)); });
    ctx.strokeStyle = ds.color; ctx.lineWidth = 2.5; ctx.stroke();
    // End label
    const last = sorted[sorted.length-1];
    ctx.font = '600 10px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'left';
    ctx.fillText(ds.label, toX(last.year)+6, toY(last.value)+3);
  });

  if (options.yLabel) {
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(options.yLabel, 0, 0); ctx.restore();
  }
}


// =========================================================
// CHART TYPE: VERTICAL BAR CHART (for Gold)
// =========================================================
function drawBarChart(canvasId, datasets, options = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  const ctx = canvas.getContext('2d');
  const W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  const pad = { top: 35, right: 40, bottom: 55, left: 70 };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);

  const ds = datasets[0];
  const sorted = ds.data.slice().sort((a,b) => a.year - b.year);
  if (sorted.length < 2) return;
  const minYear = Math.min(...sorted.map(d=>d.year));
  const maxYear = Math.max(...sorted.map(d=>d.year));
  const maxVal = (options.maxVal || Math.max(...sorted.map(d=>d.value))) * 1.1;
  const yearRange = maxYear - minYear || 1;
  function toX(yr) { return pad.left + ((yr-minYear)/yearRange)*cw; }
  function toY(v) { return H - pad.bottom - (v/maxVal)*ch; }

  // Grid
  const ySteps = 5;
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let i = 0; i <= ySteps; i++) {
    const v = maxVal*i/ySteps, y = toY(v);
    ctx.beginPath(); ctx.moveTo(pad.left,y); ctx.lineTo(W-pad.right,y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillText(options.yFormat ? options.yFormat(v) : v.toFixed(0), pad.left-8, y+3);
  }
  drawXAxis(ctx, getXTicks(minYear, maxYear), toX, W, H, pad);
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Bars
  const barW = Math.max(2, (cw / sorted.length) * 0.7);
  sorted.forEach((d, i) => {
    const x = toX(d.year) - barW/2;
    const y = toY(d.value);
    const barH = H - pad.bottom - y;
    // Gradient per bar
    const grad = ctx.createLinearGradient(0, y, 0, H-pad.bottom);
    grad.addColorStop(0, ds.color);
    grad.addColorStop(1, ds.color + '40');
    ctx.fillStyle = grad;
    ctx.fillRect(x, y, barW, barH);
    // Subtle border on top
    ctx.fillStyle = ds.color;
    ctx.fillRect(x, y, barW, 2);
  });

  // Events
  if (options.events) {
    options.events.forEach(ev => {
      const x = toX(ev.year);
      if (x >= pad.left && x <= W-pad.right) {
        ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, H-pad.bottom);
        ctx.strokeStyle = 'rgba(196,68,45,0.3)'; ctx.lineWidth = 1.5; ctx.setLineDash([4,3]); ctx.stroke(); ctx.setLineDash([]);
        ctx.save(); ctx.translate(x-4, pad.top+8); ctx.rotate(-Math.PI/2);
        ctx.font = '600 7px Inter'; ctx.fillStyle = 'rgba(196,68,45,0.7)'; ctx.textAlign = 'right';
        ctx.fillText(ev.label, 0, 0); ctx.restore();
      }
    });
  }

  // End label
  const last = sorted[sorted.length-1];
  ctx.font = '600 10px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'left';
  ctx.fillText(ds.label, toX(last.year)+barW, toY(last.value)+3);

  if (options.yLabel) {
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(options.yLabel, 0, 0); ctx.restore();
  }
}

// =========================================================
// CHART TYPE: LOLLIPOP / SPIKE CHART (for VIX)
// =========================================================
function drawLollipopChart(canvasId, datasets, options = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  const ctx = canvas.getContext('2d');
  const W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  const pad = { top: 35, right: 40, bottom: 55, left: 70 };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);

  const ds = datasets[0];
  const sorted = ds.data.slice().sort((a,b) => a.year - b.year);
  if (sorted.length < 2) return;
  const minYear = Math.min(...sorted.map(d=>d.year));
  const maxYear = Math.max(...sorted.map(d=>d.year));
  const maxVal = (options.maxVal || Math.max(...sorted.map(d=>d.value))) * 1.1;
  const yearRange = maxYear - minYear || 1;
  const baseline = options.baseline || 20; // VIX baseline "normal" level
  function toX(yr) { return pad.left + ((yr-minYear)/yearRange)*cw; }
  function toY(v) { return H - pad.bottom - (v/maxVal)*ch; }

  // Grid
  const ySteps = 5;
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let i = 0; i <= ySteps; i++) {
    const v = maxVal*i/ySteps, y = toY(v);
    ctx.beginPath(); ctx.moveTo(pad.left,y); ctx.lineTo(W-pad.right,y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillText(options.yFormat ? options.yFormat(v) : v.toFixed(0), pad.left-8, y+3);
  }
  drawXAxis(ctx, getXTicks(minYear, maxYear), toX, W, H, pad);
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Baseline zone (VIX < 20 = calm)
  const baseY = toY(baseline);
  ctx.fillStyle = 'rgba(45,110,95,0.06)';
  ctx.fillRect(pad.left, baseY, cw, H-pad.bottom-baseY);
  ctx.beginPath(); ctx.moveTo(pad.left, baseY); ctx.lineTo(W-pad.right, baseY);
  ctx.strokeStyle = 'rgba(45,110,95,0.3)'; ctx.lineWidth = 1; ctx.setLineDash([6,4]); ctx.stroke(); ctx.setLineDash([]);
  ctx.font = '500 8px Inter'; ctx.fillStyle = '#2d6e5f'; ctx.textAlign = 'left';
  ctx.fillText('CALM ZONE (<' + baseline + ')', pad.left+8, baseY+12);

  // Lollipop stems + heads
  sorted.forEach(d => {
    const x = toX(d.year);
    const y = toY(d.value);
    const baselineY = toY(0);
    const isSpike = d.value > baseline;
    // Stem
    ctx.beginPath(); ctx.moveTo(x, baselineY); ctx.lineTo(x, y);
    ctx.strokeStyle = isSpike ? ds.color + 'cc' : ds.color + '40';
    ctx.lineWidth = isSpike ? 2 : 1; ctx.stroke();
    // Head (dot)
    ctx.beginPath(); ctx.arc(x, y, isSpike ? 4 : 2.5, 0, Math.PI*2);
    ctx.fillStyle = isSpike ? ds.color : ds.color + '80';
    ctx.fill();
    if (isSpike) { ctx.strokeStyle = ds.color; ctx.lineWidth = 1; ctx.stroke(); }
  });

  // Events
  if (options.events) {
    options.events.forEach(ev => {
      const x = toX(ev.year);
      if (x >= pad.left && x <= W-pad.right) {
        ctx.save(); ctx.translate(x-4, pad.top+8); ctx.rotate(-Math.PI/2);
        ctx.font = '600 7px Inter'; ctx.fillStyle = 'rgba(196,68,45,0.7)'; ctx.textAlign = 'right';
        ctx.fillText(ev.label, 0, 0); ctx.restore();
      }
    });
  }

  // End label
  const last = sorted[sorted.length-1];
  ctx.font = '600 10px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'left';
  ctx.fillText(ds.label, toX(last.year)+8, toY(last.value)+3);

  if (options.yLabel) {
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(options.yLabel, 0, 0); ctx.restore();
  }
}

// =========================================================
// CHART TYPE: DOT PLOT WITH TREND LINE (for Forex)
// =========================================================
function drawDotPlot(canvasId, datasets, options = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  const ctx = canvas.getContext('2d');
  const W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  const pad = { top: 35, right: 40, bottom: 55, left: 70 };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);

  const ds = datasets[0];
  const sorted = ds.data.slice().sort((a,b) => a.year - b.year);
  if (sorted.length < 2) return;
  const minYear = Math.min(...sorted.map(d=>d.year));
  const maxYear = Math.max(...sorted.map(d=>d.year));
  const allVals = sorted.map(d=>d.value);
  const minVal = Math.min(...allVals) * 0.97;
  const maxVal = Math.max(...allVals) * 1.03;
  const valRange = maxVal - minVal || 1;
  const yearRange = maxYear - minYear || 1;
  function toX(yr) { return pad.left + ((yr-minYear)/yearRange)*cw; }
  function toY(v) { return H - pad.bottom - ((v-minVal)/valRange)*ch; }

  // Grid
  const ySteps = 5;
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let i = 0; i <= ySteps; i++) {
    const v = minVal + (valRange*i/ySteps), y = toY(v);
    ctx.beginPath(); ctx.moveTo(pad.left,y); ctx.lineTo(W-pad.right,y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillText(options.yFormat ? options.yFormat(v) : v.toFixed(3), pad.left-8, y+3);
  }
  drawXAxis(ctx, getXTicks(minYear, maxYear), toX, W, H, pad);
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Moving average trend line (adaptive window)
  const windowSize = Math.min(22, Math.max(5, Math.floor(sorted.length / 12)));
  if (windowSize >= 2) {
    ctx.beginPath();
    let first = true;
    for (let i = windowSize-1; i < sorted.length; i++) {
      let sum = 0;
      for (let j = i-windowSize+1; j <= i; j++) sum += sorted[j].value;
      const avg = sum / windowSize;
      const x = toX(sorted[i].year), y = toY(avg);
      first ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
      first = false;
    }
    ctx.strokeStyle = ds.color; ctx.lineWidth = 3; ctx.stroke();
  }

  // Dots
  sorted.forEach(d => {
    const x = toX(d.year), y = toY(d.value);
    // Connecting line to moving avg (subtle)
    ctx.beginPath(); ctx.arc(x, y, 3.5, 0, Math.PI*2);
    ctx.fillStyle = ds.color + '90'; ctx.fill();
    ctx.strokeStyle = ds.color; ctx.lineWidth = 1; ctx.stroke();
  });

  // Events
  if (options.events) {
    options.events.forEach(ev => {
      const x = toX(ev.year);
      if (x >= pad.left && x <= W-pad.right) {
        ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, H-pad.bottom);
        ctx.strokeStyle = 'rgba(196,68,45,0.25)'; ctx.lineWidth = 1; ctx.setLineDash([4,3]); ctx.stroke(); ctx.setLineDash([]);
        ctx.save(); ctx.translate(x-4, pad.top+8); ctx.rotate(-Math.PI/2);
        ctx.font = '600 7px Inter'; ctx.fillStyle = 'rgba(196,68,45,0.7)'; ctx.textAlign = 'right';
        ctx.fillText(ev.label, 0, 0); ctx.restore();
      }
    });
  }

  // Legend
  var _freq = sorted.length > 100 ? 'Daily' : 'Monthly';
  ctx.font = '500 9px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'left';
  ctx.beginPath(); ctx.arc(pad.left+10, H-10, 3, 0, Math.PI*2); ctx.fill();
  ctx.fillText(_freq + ' rate', pad.left+20, H-7);
  ctx.beginPath(); ctx.moveTo(pad.left+100, H-10); ctx.lineTo(pad.left+130, H-10);
  ctx.strokeStyle = ds.color; ctx.lineWidth = 3; ctx.stroke();
  ctx.fillText('Moving avg', pad.left+136, H-7);

  if (options.yLabel) {
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(options.yLabel, 0, 0); ctx.restore();
  }
}

// =========================================================
// CHART TYPE: STEPPED AREA CHART (for Oil)
// =========================================================
function drawSteppedArea(canvasId, datasets, options = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  const ctx = canvas.getContext('2d');
  const W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  const pad = { top: 35, right: 40, bottom: 55, left: 70 };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);

  let allYears = [], allVals = [];
  datasets.forEach(ds => ds.data.forEach(d => { allYears.push(d.year); allVals.push(d.value); }));
  const minYear = Math.min(...allYears), maxYear = Math.max(...allYears);
  const minVal = 0, maxVal = Math.max(...allVals) * 1.1;
  const valRange = maxVal || 1, yearRange = maxYear - minYear || 1;
  function toX(yr) { return pad.left + ((yr-minYear)/yearRange)*cw; }
  function toY(v) { return H - pad.bottom - (v/valRange)*ch; }

  // Grid
  const ySteps = 5;
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let i = 0; i <= ySteps; i++) {
    const v = valRange*i/ySteps, y = toY(v);
    ctx.beginPath(); ctx.moveTo(pad.left,y); ctx.lineTo(W-pad.right,y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillText(options.yFormat ? options.yFormat(v) : v.toFixed(0), pad.left-8, y+3);
  }
  drawXAxis(ctx, getXTicks(minYear, maxYear), toX, W, H, pad);
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Event markers BEHIND the area
  if (options.events) {
    options.events.forEach(ev => {
      const x = toX(ev.year);
      if (x >= pad.left && x <= W-pad.right) {
        ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, H-pad.bottom);
        ctx.strokeStyle = 'rgba(196,68,45,0.3)'; ctx.lineWidth = 1.5; ctx.setLineDash([4,3]); ctx.stroke(); ctx.setLineDash([]);
        ctx.save(); ctx.translate(x-4, pad.top+8); ctx.rotate(-Math.PI/2);
        ctx.font = '600 7px Inter'; ctx.fillStyle = 'rgba(196,68,45,0.7)'; ctx.textAlign = 'right';
        ctx.fillText(ev.label, 0, 0); ctx.restore();
      }
    });
  }

  // Draw stepped area
  datasets.forEach(ds => {
    const sorted = ds.data.slice().sort((a,b)=>a.year-b.year);
    if (sorted.length < 2) return;

    // Build stepped path
    ctx.beginPath();
    ctx.moveTo(toX(sorted[0].year), toY(sorted[0].value));
    for (let i = 1; i < sorted.length; i++) {
      // Horizontal step to new x, then vertical step to new y
      ctx.lineTo(toX(sorted[i].year), toY(sorted[i-1].value));
      ctx.lineTo(toX(sorted[i].year), toY(sorted[i].value));
    }
    // Fill
    const lastX = toX(sorted[sorted.length-1].year);
    const firstX = toX(sorted[0].year);
    ctx.lineTo(lastX, H-pad.bottom);
    ctx.lineTo(firstX, H-pad.bottom);
    ctx.closePath();
    const grad = ctx.createLinearGradient(0, pad.top, 0, H-pad.bottom);
    grad.addColorStop(0, ds.color + '35');
    grad.addColorStop(0.7, ds.color + '10');
    grad.addColorStop(1, ds.color + '02');
    ctx.fillStyle = grad; ctx.fill();

    // Stroke
    ctx.beginPath();
    ctx.moveTo(toX(sorted[0].year), toY(sorted[0].value));
    for (let i = 1; i < sorted.length; i++) {
      ctx.lineTo(toX(sorted[i].year), toY(sorted[i-1].value));
      ctx.lineTo(toX(sorted[i].year), toY(sorted[i].value));
    }
    ctx.strokeStyle = ds.color; ctx.lineWidth = 2; ctx.stroke();

    // Peak marker
    const peak = sorted.reduce((a,b)=>b.value>a.value?b:a);
    const px = toX(peak.year), py = toY(peak.value);
    ctx.beginPath(); ctx.arc(px, py, 5, 0, Math.PI*2);
    ctx.fillStyle = '#fff'; ctx.fill();
    ctx.strokeStyle = ds.color; ctx.lineWidth = 2; ctx.stroke();
    ctx.font = '600 9px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'center';
    ctx.fillText(options.yFormat ? options.yFormat(peak.value) : peak.value.toFixed(0), px, py-10);

    // End label
    const last = sorted[sorted.length-1];
    ctx.font = '600 10px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'left';
    ctx.fillText(ds.label, toX(last.year)+6, toY(last.value)+3);
  });

  if (options.yLabel) {
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(options.yLabel, 0, 0); ctx.restore();
  }
}

function setStatus(id, text, state) {
  const el = document.getElementById(id);
  if (el) { el.textContent = text; el.className = 'real-chart-status' + (state ? ' ' + state : ''); }
}

// --- TREASURY SPREAD CHART (Zero-Crossing Visualization) ---
function drawSpreadChart(canvasId, data, options) {
  options = options || {};
  var canvas = document.getElementById(canvasId);
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  var ctx = canvas.getContext('2d');
  var W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  var pad = { top: 35, right: 40, bottom: 55, left: 70 };
  var cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);
  if (!data.length) return;

  var vals = data.map(function(d) { return d.value; });
  var absMax = Math.max(Math.abs(Math.min.apply(null, vals)), Math.abs(Math.max.apply(null, vals))) * 1.2;
  if (absMax < 0.5) absMax = 0.5;
  var minVal = -absMax, maxVal = absMax, valRange = maxVal - minVal;
  var minYear = data[0].year, maxYear = data[data.length - 1].year, yearRange = maxYear - minYear || 1;

  function toX(yr) { return pad.left + ((yr - minYear) / yearRange) * cw; }
  function toY(v) { return pad.top + ch - ((v - minVal) / valRange) * ch; }

  // Y-axis gridlines
  ctx.font = '400 9px Inter'; ctx.textAlign = 'right';
  var step = absMax > 2 ? 1 : absMax > 1 ? 0.5 : 0.25;
  for (var v = Math.ceil(-absMax / step) * step; v <= absMax; v += step) {
    var y = toY(v);
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(pad.left + cw, y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillStyle = '#a3a8a0';
    if (Math.abs(v) > 0.01) ctx.fillText((v > 0 ? '+' : '') + v.toFixed(1) + '%', pad.left - 8, y + 3);
  }
  // X-axis ticks
  drawXAxis(ctx, getXTicks(minYear, maxYear), toX, W, H, pad);
  // Axes
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, pad.top + ch); ctx.lineTo(pad.left + cw, pad.top + ch); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, pad.top + ch); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Event markers
  if (options.events) {
    options.events.forEach(function(ev) {
      var x = toX(ev.year);
      if (x >= pad.left && x <= pad.left + cw) {
        ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, pad.top + ch);
        ctx.strokeStyle = 'rgba(196,68,45,0.3)'; ctx.lineWidth = 1.5; ctx.setLineDash([4, 3]); ctx.stroke(); ctx.setLineDash([]);
        ctx.save(); ctx.translate(x - 4, pad.top + 8); ctx.rotate(-Math.PI / 2);
        ctx.font = '600 7px Inter'; ctx.fillStyle = 'rgba(196,68,45,0.7)'; ctx.textAlign = 'right';
        ctx.fillText(ev.label, 0, 0); ctx.restore();
      }
    });
  }

  // Zero line
  var zeroY = toY(0);
  ctx.beginPath(); ctx.moveTo(pad.left, zeroY); ctx.lineTo(pad.left + cw, zeroY);
  ctx.strokeStyle = 'rgba(0,0,0,0.25)'; ctx.lineWidth = 2; ctx.stroke();
  ctx.font = '600 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'right';
  ctx.fillText('0.0%', pad.left - 8, zeroY + 3);

  // Build full area path
  var fullPath = new Path2D();
  fullPath.moveTo(toX(data[0].year), toY(data[0].value));
  for (var i = 1; i < data.length; i++) fullPath.lineTo(toX(data[i].year), toY(data[i].value));
  fullPath.lineTo(toX(data[data.length - 1].year), zeroY);
  fullPath.lineTo(toX(data[0].year), zeroY);
  fullPath.closePath();

  // Positive fill (green — above zero)
  ctx.save();
  ctx.beginPath(); ctx.rect(pad.left, pad.top, cw, zeroY - pad.top); ctx.clip();
  var posGrad = ctx.createLinearGradient(0, pad.top, 0, zeroY);
  posGrad.addColorStop(0, 'rgba(45,110,95,0.30)'); posGrad.addColorStop(1, 'rgba(45,110,95,0.03)');
  ctx.fillStyle = posGrad; ctx.fill(fullPath);
  ctx.restore();

  // Negative fill (red — below zero)
  ctx.save();
  ctx.beginPath(); ctx.rect(pad.left, zeroY, cw, pad.top + ch - zeroY); ctx.clip();
  var negGrad = ctx.createLinearGradient(0, zeroY, 0, pad.top + ch);
  negGrad.addColorStop(0, 'rgba(196,68,45,0.03)'); negGrad.addColorStop(1, 'rgba(196,68,45,0.30)');
  ctx.fillStyle = negGrad; ctx.fill(fullPath);
  ctx.restore();

  // Main line
  ctx.beginPath();
  data.forEach(function(d, i) {
    var x = toX(d.year), y2 = toY(d.value);
    i === 0 ? ctx.moveTo(x, y2) : ctx.lineTo(x, y2);
  });
  ctx.strokeStyle = '#1a1c1b'; ctx.lineWidth = 2; ctx.stroke();

  // Region labels
  ctx.font = '600 8px Inter'; ctx.textAlign = 'left';
  ctx.fillStyle = 'rgba(45,110,95,0.5)'; ctx.fillText('NORMAL YIELD CURVE', pad.left + 8, zeroY - 10);
  ctx.fillStyle = 'rgba(196,68,45,0.5)'; ctx.fillText('INVERTED — RECESSION SIGNAL', pad.left + 8, zeroY + 16);

  // Latest value label
  var last = data[data.length - 1];
  ctx.font = '600 10px Inter'; ctx.fillStyle = last.value >= 0 ? '#2d6e5f' : '#c4442d';
  ctx.textAlign = 'left';
  ctx.fillText((last.value >= 0 ? '+' : '') + last.value.toFixed(2) + '%', toX(last.year) + 6, toY(last.value) + 3);

  // Y axis label
  ctx.save(); ctx.translate(12, H / 2); ctx.rotate(-Math.PI / 2);
  ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
  ctx.fillText('10Y–2Y SPREAD (PERCENTAGE POINTS)', 0, 0); ctx.restore();
}

// =========================================================
// MOBILE DATA THINNING — fewer points + fewer events on small screens
// =========================================================
var _isMobile = window.innerWidth <= 768;
function thinData(arr, n) {
  if (!arr || arr.length <= n) return arr;
  var step = Math.ceil(arr.length / n);
  var result = [];
  for (var i = 0; i < arr.length; i += step) result.push(arr[i]);
  if (result[result.length - 1] !== arr[arr.length - 1]) result.push(arr[arr.length - 1]);
  return result;
}
function mobileEvents(events, max) {
  if (!_isMobile || !events) return events;
  if (events.length <= max) return events;
  var step = Math.floor(events.length / max);
  var result = [];
  for (var i = 0; i < events.length; i += step) { result.push(events[i]); if (result.length >= max) break; }
  return result;
}

// =========================================================
// LIVE FRED DATA — fetched from /api/fred serverless function
// =========================================================
var FRED_DOLLAR = [], FRED_GOLD = [], FRED_OIL = [], FRED_TREASURY = [], FRED_VIX = [], FRED_FOREX = [];
var _fullData = {};
var _ranges = {};
var _fredReady = null; // Promise that resolves when FRED data is loaded
var CHART_REDRAW = {};

// Value formatters for the latest-value badge
var LATEST_FMT = {
  dollar: function(v) { return v.toFixed(1); },
  gold: function(v) { return v.toFixed(0); },
  oil: function(v) { return '$' + v.toFixed(2); },
  treasury: function(v) { return (v >= 0 ? '+' : '') + v.toFixed(2) + '%'; },
  vix: function(v) { return v.toFixed(1); },
  forex: function(v) { return v.toFixed(4); }
};

function filterByRange(data, range) {
  if (!data || !data.length || range === 'all') return data;
  var latest = data[data.length - 1].year;
  var months = { '1m': 1, '3m': 3, '6m': 6, '1y': 12 }[range] || 12;
  var cutoff = latest - months / 12;
  return data.filter(function(d) { return d.year >= cutoff; });
}

function updateLatest(elId, data, fmt) {
  var el = document.getElementById(elId);
  if (!el || !data || !data.length) return;
  var last = data[data.length - 1];
  var prev = data.length > 1 ? data[data.length - 2] : last;
  var change = last.value - prev.value;
  var pct = prev.value !== 0 ? ((change / prev.value) * 100) : 0;
  var arrow = change >= 0 ? '▲' : '▼';
  var color = change >= 0 ? '#2d6e5f' : '#c4442d';
  var valStr = fmt ? fmt(last.value) : last.value.toFixed(2);
  el.innerHTML = '<span class="latest-pulse"></span>' +
    '<strong>' + valStr + '</strong> ' +
    '<span style="color:' + color + ';font-size:10px">' + arrow + ' ' + (change >= 0 ? '+' : '') + pct.toFixed(1) + '%</span> ' +
    '<span class="latest-date">' + last.date + '</span>';
}

function setChartRange(name, range) {
  _ranges[name] = range;
  // Update button state immediately
  document.querySelectorAll('.chart-range-btns[data-chart="' + name + '"] .range-btn').forEach(function(b) {
    b.classList.toggle('active', b.dataset.range === range);
  });
  var full = _fullData[name];
  if (!full || !full.length) return;
  var filtered = filterByRange(full, range);
  var data = _isMobile ? thinData(filtered, 50) : filtered;
  _chartData[name] = data;
  if (CHART_REDRAW[name]) CHART_REDRAW[name](data);
  updateLatest(name + '-latest', full, LATEST_FMT[name]);
}

// Delegated click handler for time-range buttons
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.range-btn');
  if (!btn) return;
  var wrap = btn.closest('.chart-range-btns');
  if (!wrap) return;
  setChartRange(wrap.dataset.chart, btn.dataset.range);
});

