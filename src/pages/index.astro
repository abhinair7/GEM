// =========================================================
// REAL DATA CHARTS — World Bank API + FRED
// =========================================================

// =========================================================
// CHART TYPE 1: GROUPED BAR CHART (for GDP)
// =========================================================
function drawGroupedBar(canvasId, datasets, options = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = { top: 35, right: 130, bottom: 55, left: 70 };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);

  // Group data by decade
  const decades = {};
  datasets.forEach(ds => {
    ds.data.forEach(d => {
      const dec = Math.floor(d.year / 10) * 10;
      if (!decades[dec]) decades[dec] = {};
      if (!decades[dec][ds.label]) decades[dec][ds.label] = [];
      decades[dec][ds.label].push(d.value);
    });
  });
  const decadeKeys = Object.keys(decades).map(Number).sort((a,b)=>a-b);
  const decadeAvgs = decadeKeys.map(dec => {
    const obj = { decade: dec };
    datasets.forEach(ds => {
      const vals = decades[dec]?.[ds.label] || [];
      obj[ds.label] = vals.length ? vals.reduce((s,v)=>s+v,0)/vals.length : 0;
    });
    return obj;
  });

  let maxVal = 0;
  decadeAvgs.forEach(d => datasets.forEach(ds => { maxVal = Math.max(maxVal, d[ds.label] || 0); }));
  maxVal = maxVal * 1.1;

  // Y-axis grid
  const ySteps = 5;
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let i = 0; i <= ySteps; i++) {
    const v = (maxVal * i / ySteps);
    const y = H - pad.bottom - (v / maxVal) * ch;
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W-pad.right, y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    const label = options.yFormat ? options.yFormat(v) : v.toFixed(0);
    ctx.fillText(label, pad.left - 8, y + 3);
  }
  // Axes
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Event markers
  if (options.events) {
    options.events.forEach(ev => {
      const decIdx = decadeKeys.findIndex(d => d <= ev.year && d+10 > ev.year);
      if (decIdx >= 0) {
        const groupW = cw / decadeKeys.length;
        const x = pad.left + decIdx * groupW + groupW / 2;
        ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, H-pad.bottom);
        ctx.strokeStyle = 'rgba(196,68,45,0.2)'; ctx.setLineDash([3,3]); ctx.lineWidth = 1; ctx.stroke(); ctx.setLineDash([]);
        ctx.font = '500 7px Inter'; ctx.fillStyle = 'rgba(196,68,45,0.5)'; ctx.textAlign = 'center';
        ctx.fillText(ev.label, x, pad.top - 4);
      }
    });
  }

  // Draw bars
  const nGroups = decadeKeys.length;
  const nBars = datasets.length;
  const groupW = cw / nGroups;
  const barGap = 4;
  const barW = (groupW - barGap * (nBars + 1)) / nBars;
  decadeAvgs.forEach((d, gi) => {
    const gx = pad.left + gi * groupW;
    datasets.forEach((ds, bi) => {
      const val = d[ds.label] || 0;
      const barH = (val / maxVal) * ch;
      const x = gx + barGap * (bi + 1) + barW * bi;
      const y = H - pad.bottom - barH;
      // Bar with subtle gradient
      const grad = ctx.createLinearGradient(x, y, x, H - pad.bottom);
      grad.addColorStop(0, ds.color);
      grad.addColorStop(1, ds.color + '66');
      ctx.fillStyle = grad;
      // Rounded top corners
      const r = Math.min(3, barW / 4);
      ctx.beginPath();
      ctx.moveTo(x + r, y); ctx.lineTo(x + barW - r, y);
      ctx.quadraticCurveTo(x + barW, y, x + barW, y + r);
      ctx.lineTo(x + barW, H - pad.bottom); ctx.lineTo(x, H - pad.bottom);
      ctx.lineTo(x, y + r); ctx.quadraticCurveTo(x, y, x + r, y);
      ctx.closePath(); ctx.fill();
      // Value label on top
      if (barH > 20) {
        ctx.font = '600 8px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'center';
        const lbl = options.yFormat ? options.yFormat(val) : val.toFixed(0);
        ctx.fillText(lbl, x + barW/2, y - 5);
      }
    });
    // Decade label
    ctx.font = '500 10px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(d.decade + 's', gx + groupW/2, H - pad.bottom + 18);
  });

  // Legend
  let ly = pad.top + 10;
  datasets.forEach(ds => {
    ctx.fillStyle = ds.color;
    ctx.fillRect(W-pad.right+16, ly, 14, 14);
    ctx.font = '500 10px Inter'; ctx.fillStyle = '#44474e'; ctx.textAlign = 'left';
    ctx.fillText(ds.label, W-pad.right+36, ly+11);
    ly += 22;
  });

  // Y-axis label
  if (options.yLabel) {
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(options.yLabel, 0, 0); ctx.restore();
  }
}

// =========================================================
// CHART TYPE 2: SMOOTH AREA CHART (for Trade)
// =========================================================
function drawAreaChart(canvasId, datasets, options = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = { top: 35, right: 40, bottom: 55, left: 70 };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);

  let allYears = [], allVals = [];
  datasets.forEach(ds => ds.data.forEach(d => { allYears.push(d.year); allVals.push(d.value); }));
  const minYear = Math.min(...allYears), maxYear = Math.max(...allYears);
  const minVal = 0, maxVal = (options.maxVal || Math.max(...allVals)) * 1.1;
  const valRange = maxVal - minVal || 1;
  const yearRange = maxYear - minYear || 1;
  function toX(yr) { return pad.left + ((yr-minYear)/yearRange)*cw; }
  function toY(v) { return H - pad.bottom - ((v-minVal)/valRange)*ch; }

  // Grid
  const ySteps = 5;
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let i = 0; i <= ySteps; i++) {
    const v = minVal + (valRange*i/ySteps), y = toY(v);
    ctx.beginPath(); ctx.moveTo(pad.left,y); ctx.lineTo(W-pad.right,y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillText(options.yFormat ? options.yFormat(v) : v.toFixed(0), pad.left-8, y+3);
  }
  // X labels
  ctx.textAlign = 'center'; const xInt = yearRange > 50 ? 10 : yearRange > 25 ? 5 : 2;
  for (let yr = Math.ceil(minYear/xInt)*xInt; yr <= maxYear; yr += xInt) {
    ctx.beginPath(); ctx.moveTo(toX(yr), H-pad.bottom); ctx.lineTo(toX(yr), pad.top);
    ctx.strokeStyle = 'rgba(0,0,0,0.03)'; ctx.stroke();
    ctx.fillStyle = '#a3a8a0'; ctx.fillText(yr.toString(), toX(yr), H-pad.bottom+16);
  }
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Draw filled areas (back to front so first dataset is on top)
  [...datasets].reverse().forEach(ds => {
    const sorted = ds.data.slice().sort((a,b)=>a.year-b.year);
    if (sorted.length < 2) return;
    // Filled area with gradient
    ctx.beginPath();
    sorted.forEach((d,i) => { i===0 ? ctx.moveTo(toX(d.year),toY(d.value)) : ctx.lineTo(toX(d.year),toY(d.value)); });
    ctx.lineTo(toX(sorted[sorted.length-1].year), H-pad.bottom);
    ctx.lineTo(toX(sorted[0].year), H-pad.bottom);
    ctx.closePath();
    const grad = ctx.createLinearGradient(0, pad.top, 0, H-pad.bottom);
    grad.addColorStop(0, ds.color + '30');
    grad.addColorStop(1, ds.color + '05');
    ctx.fillStyle = grad; ctx.fill();
    // Stroke
    ctx.beginPath();
    sorted.forEach((d,i) => { i===0 ? ctx.moveTo(toX(d.year),toY(d.value)) : ctx.lineTo(toX(d.year),toY(d.value)); });
    ctx.strokeStyle = ds.color; ctx.lineWidth = 2.5; ctx.stroke();
    // End label
    const last = sorted[sorted.length-1];
    ctx.font = '600 10px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'left';
    ctx.fillText(ds.label, toX(last.year)+6, toY(last.value)+3);
  });

  if (options.yLabel) {
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(options.yLabel, 0, 0); ctx.restore();
  }
}


// =========================================================
// CHART TYPE 6: STEPPED AREA CHART (for Oil)
// =========================================================
function drawSteppedArea(canvasId, datasets, options = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = { top: 35, right: 40, bottom: 55, left: 70 };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  ctx.clearRect(0, 0, W, H);

  let allYears = [], allVals = [];
  datasets.forEach(ds => ds.data.forEach(d => { allYears.push(d.year); allVals.push(d.value); }));
  const minYear = Math.min(...allYears), maxYear = Math.max(...allYears);
  const minVal = 0, maxVal = Math.max(...allVals) * 1.1;
  const valRange = maxVal || 1, yearRange = maxYear - minYear || 1;
  function toX(yr) { return pad.left + ((yr-minYear)/yearRange)*cw; }
  function toY(v) { return H - pad.bottom - (v/valRange)*ch; }

  // Grid
  const ySteps = 5;
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let i = 0; i <= ySteps; i++) {
    const v = valRange*i/ySteps, y = toY(v);
    ctx.beginPath(); ctx.moveTo(pad.left,y); ctx.lineTo(W-pad.right,y);
    ctx.strokeStyle = 'rgba(0,0,0,0.04)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillText(options.yFormat ? options.yFormat(v) : v.toFixed(0), pad.left-8, y+3);
  }
  const xInt = yearRange > 30 ? 5 : yearRange > 15 ? 2 : 1;
  ctx.textAlign = 'center';
  for (let yr = Math.ceil(minYear/xInt)*xInt; yr <= maxYear; yr += xInt) {
    ctx.beginPath(); ctx.moveTo(toX(yr), H-pad.bottom); ctx.lineTo(toX(yr), pad.top);
    ctx.strokeStyle = 'rgba(0,0,0,0.03)'; ctx.stroke();
    ctx.fillStyle = '#a3a8a0'; ctx.fillText(yr.toString(), toX(yr), H-pad.bottom+16);
  }
  ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Event markers BEHIND the area
  if (options.events) {
    options.events.forEach(ev => {
      const x = toX(ev.year);
      if (x >= pad.left && x <= W-pad.right) {
        ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, H-pad.bottom);
        ctx.strokeStyle = 'rgba(196,68,45,0.3)'; ctx.lineWidth = 1.5; ctx.setLineDash([4,3]); ctx.stroke(); ctx.setLineDash([]);
        ctx.save(); ctx.translate(x-4, pad.top+8); ctx.rotate(-Math.PI/2);
        ctx.font = '600 7px Inter'; ctx.fillStyle = 'rgba(196,68,45,0.7)'; ctx.textAlign = 'right';
        ctx.fillText(ev.label, 0, 0); ctx.restore();
      }
    });
  }

  // Draw stepped area
  datasets.forEach(ds => {
    const sorted = ds.data.slice().sort((a,b)=>a.year-b.year);
    if (sorted.length < 2) return;

    // Build stepped path
    ctx.beginPath();
    ctx.moveTo(toX(sorted[0].year), toY(sorted[0].value));
    for (let i = 1; i < sorted.length; i++) {
      // Horizontal step to new x, then vertical step to new y
      ctx.lineTo(toX(sorted[i].year), toY(sorted[i-1].value));
      ctx.lineTo(toX(sorted[i].year), toY(sorted[i].value));
    }
    // Fill
    const lastX = toX(sorted[sorted.length-1].year);
    const firstX = toX(sorted[0].year);
    ctx.lineTo(lastX, H-pad.bottom);
    ctx.lineTo(firstX, H-pad.bottom);
    ctx.closePath();
    const grad = ctx.createLinearGradient(0, pad.top, 0, H-pad.bottom);
    grad.addColorStop(0, ds.color + '35');
    grad.addColorStop(0.7, ds.color + '10');
    grad.addColorStop(1, ds.color + '02');
    ctx.fillStyle = grad; ctx.fill();

    // Stroke
    ctx.beginPath();
    ctx.moveTo(toX(sorted[0].year), toY(sorted[0].value));
    for (let i = 1; i < sorted.length; i++) {
      ctx.lineTo(toX(sorted[i].year), toY(sorted[i-1].value));
      ctx.lineTo(toX(sorted[i].year), toY(sorted[i].value));
    }
    ctx.strokeStyle = ds.color; ctx.lineWidth = 2; ctx.stroke();

    // Peak marker
    const peak = sorted.reduce((a,b)=>b.value>a.value?b:a);
    const px = toX(peak.year), py = toY(peak.value);
    ctx.beginPath(); ctx.arc(px, py, 5, 0, Math.PI*2);
    ctx.fillStyle = '#fff'; ctx.fill();
    ctx.strokeStyle = ds.color; ctx.lineWidth = 2; ctx.stroke();
    ctx.font = '600 9px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'center';
    ctx.fillText(options.yFormat ? options.yFormat(peak.value) : peak.value.toFixed(0), px, py-10);

    // End label
    const last = sorted[sorted.length-1];
    ctx.font = '600 10px Inter'; ctx.fillStyle = ds.color; ctx.textAlign = 'left';
    ctx.fillText(ds.label, toX(last.year)+6, toY(last.value)+3);
  });

  if (options.yLabel) {
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
    ctx.fillText(options.yLabel, 0, 0); ctx.restore();
  }
}

// --- WORLD BANK API FETCHER ---
async function fetchWorldBank(indicator, countryCode, startYear, endYear) {
  const url = `https://api.worldbank.org/v2/country/${countryCode}/indicator/${indicator}?date=${startYear}:${endYear}&format=json&per_page=500`;
  const resp = await fetch(url);
  if (!resp.ok) throw new Error('World Bank API ' + resp.status);
  const json = await resp.json();
  if (!json[1]) return [];
  return json[1]
    .filter(d => d.value !== null)
    .map(d => ({ year: parseInt(d.date), value: d.value }))
    .sort((a, b) => a.year - b.year);
}

function setStatus(id, text, state) {
  const el = document.getElementById(id);
  if (el) { el.textContent = text; el.className = 'real-chart-status' + (state ? ' ' + state : ''); }
}

// --- 1. GDP PER CAPITA — GROUPED BAR CHART ---
async function loadGDPChart() {
  try {
    const [usData, irData] = await Promise.all([
      fetchWorldBank('NY.GDP.PCAP.KD', 'US', 1960, 2023),
      fetchWorldBank('NY.GDP.PCAP.KD', 'IR', 1960, 2023)
    ]);
    setStatus('gdp-status', '✦ ' + (usData.length + irData.length) + ' data points loaded — World Bank Open Data', 'loaded');
    drawGroupedBar('gdp-chart', [
      { label: 'United States', data: usData, color: '#44474e' },
      { label: 'Iran', data: irData, color: '#c4442d' }
    ], {
      yLabel: 'GDP PER CAPITA (CONSTANT 2015 USD)',
      yFormat: v => '$' + (v >= 1000 ? (v/1000).toFixed(0) + 'k' : v.toFixed(0)),
      events: [
        { year: 1979, label: 'Iranian Revolution' },
        { year: 2012, label: 'Oil Sanctions Peak' },
        { year: 2018, label: 'JCPOA Withdrawal' }
      ]
    });
  } catch(e) {
    setStatus('gdp-status', '✗ Failed to load: ' + e.message, 'error');
  }
}

// --- 2. TRADE OPENNESS — AREA CHART ---
async function loadTradeChart() {
  try {
    const [usData, irData] = await Promise.all([
      fetchWorldBank('NE.TRD.GNFS.ZS', 'US', 1960, 2023),
      fetchWorldBank('NE.TRD.GNFS.ZS', 'IR', 1960, 2023)
    ]);
    setStatus('trade-status', '✦ ' + (usData.length + irData.length) + ' pts — World Bank', 'loaded');
    drawAreaChart('trade-chart', [
      { label: 'U.S.', data: usData, color: '#44474e' },
      { label: 'Iran', data: irData, color: '#c4442d' }
    ], { yLabel: 'TRADE (% OF GDP)', yFormat: v => v.toFixed(0) + '%' });
  } catch(e) { setStatus('trade-status', '✗ ' + e.message, 'error'); }
}

// --- 3. BRENT CRUDE OIL — STEPPED AREA CHART ---
async function loadOilChart() {
  try {
    const resp = await fetch('https://fred.stlouisfed.org/graph/fredgraph.csv?bgcolor=%23e1e9f0&chart_type=line&drp=0&fo=open%20sans&graph_bgcolor=%23ffffff&height=450&mode=fred&recession_bars=on&txtcolor=%23444444&ts=12&tts=12&width=1168&nt=0&thu=0&trc=0&show_legend=yes&show_axis_titles=yes&show_tooltip=yes&id=DCOILBRENTEU&scale=left&cosd=1987-05-20&coed=2025-03-31&line_color=%234572a7&link_values=false&line_style=solid&mark_type=none&mw=3&lw=2&ost=-99999&oet=99999&mma=0&fml=a&fq=Monthly&fam=avg&fgst=lin&fgsnd=2020-02-01&line_index=1&transformation=lin&vintage_date=2025-04-01&revision_date=2025-04-01&nd=1987-05-20');
    if (!resp.ok) throw new Error('FRED API ' + resp.status);
    const csv = await resp.text();
    const lines = csv.trim().split('\n').slice(1);
    const data = [];
    lines.forEach(line => {
      const [dateStr, valStr] = line.split(',');
      if (valStr && valStr !== '.' && !isNaN(parseFloat(valStr))) {
        const year = parseInt(dateStr.split('-')[0]);
        const month = parseInt(dateStr.split('-')[1]);
        data.push({ year: year + (month - 1) / 12, value: parseFloat(valStr) });
      }
    });
    const byYear = {};
    data.forEach(d => {
      const yr = Math.round(d.year * 2) / 2;
      if (!byYear[yr]) byYear[yr] = [];
      byYear[yr].push(d.value);
    });
    const averaged = Object.entries(byYear).map(([yr, vals]) => ({
      year: parseFloat(yr),
      value: vals.reduce((s, v) => s + v, 0) / vals.length
    })).sort((a, b) => a.year - b.year);

    setStatus('oil-status', '✦ ' + data.length + ' observations loaded — FRED (Brent Crude)', 'loaded');
    drawSteppedArea('oil-chart', [
      { label: 'Brent Crude ($/bbl)', data: averaged, color: '#2d6e5f' }
    ], {
      yLabel: 'PRICE PER BARREL (USD)',
      yFormat: v => '$' + v.toFixed(0),
      events: [
        { year: 1990.6, label: 'Gulf War I' },
        { year: 1997, label: 'Asian Crisis' },
        { year: 2003.3, label: 'Iraq Invasion' },
        { year: 2008.5, label: '$147 Peak / GFC' },
        { year: 2011, label: 'Arab Spring' },
        { year: 2014.5, label: 'Oil Glut' },
        { year: 2020.2, label: 'COVID Crash' },
        { year: 2022.2, label: 'Ukraine War' }
      ]
    });
  } catch(e) {
    setStatus('oil-status', '✗ FRED CORS blocked — loading fallback via World Bank crude proxy', 'error');
    try {
      const oilData = await fetchWorldBank('NY.GDP.PETR.RT.ZS', 'IR', 1970, 2023);
      setStatus('oil-status', '✦ Fallback: Iran Oil Rents (% GDP) — ' + oilData.length + ' pts — World Bank', 'loaded');
      drawSteppedArea('oil-chart', [
        { label: 'Iran Oil Rents (% GDP)', data: oilData, color: '#2d6e5f' }
      ], {
        yLabel: 'OIL RENTS (% OF GDP)',
        yFormat: v => v.toFixed(1) + '%',
        events: [
          { year: 1979, label: 'Revolution' },
          { year: 1990, label: 'Gulf War' },
          { year: 2003, label: 'Iraq War' },
          { year: 2012, label: 'Sanctions Peak' },
          { year: 2018, label: 'JCPOA Exit' }
        ]
      });
    } catch(e2) {
      setStatus('oil-status', '✗ All sources failed: ' + e2.message, 'error');
    }
  }
}

// --- AI ERA INTELLIGENCE FLASHCARDS ---
let eraIntelGenerated = false;
const eraIntelBtn = document.getElementById('era-intel-btn');
if (eraIntelBtn) {
  eraIntelBtn.addEventListener('click', () => generateEraIntel());
}

async function generateEraIntel() {
  if (!CEREBRAS_KEY) { alert('AI key not configured'); return; }
  const btn = document.getElementById('era-intel-btn');
  btn.disabled = true;
  btn.classList.add('generating');
  btn.textContent = '⟳ Generating Intelligence…';

  // Collect chart data summaries from the status elements
  const gdpStatus = document.getElementById('gdp-status')?.textContent || '';
  const tradeStatus = document.getElementById('trade-status')?.textContent || '';
  const oilStatus = document.getElementById('oil-status')?.textContent || '';

  const eraKeys = ['romana', 'song', 'renaissance', 'twenties', 'golden', 'nineties'];
  const eraLabels = {
    romana: 'Pax Romana (27 BC–180 AD)',
    song: 'Song Dynasty (960–1279 AD)',
    renaissance: 'Italian Renaissance (1450–1600)',
    twenties: 'Roaring Twenties (1920s USA)',
    golden: 'Golden Age USA (1950s)',
    nineties: 'Information Age (1990s)',
  };

  const prompt = `You are analysing real-world economic data for the Geopolitical Equilibrium Model (GEM). The data includes:

1. GDP Per Capita (U.S. vs Iran): U.S. GDP per capita is roughly $55,000–$65,000 (constant 2015 USD), while Iran is around $5,000–$7,000. The gap has widened since the 1979 revolution and especially after 2012 sanctions.

2. Trade Openness (% GDP): U.S. trades at 25–30% of GDP. Iran collapsed from 50%+ to under 40% post-sanctions. Economic isolation is visible.

3. Brent Crude Oil: Oil prices spiked during Gulf Wars, 2008 ($140), crashed in 2014 and 2020. Currently $70–$85. Every major price shock correlates with Middle East geopolitical events.

For EACH of the 6 historical eras below, write a 2–3 sentence analytical conclusion connecting what this modern economic data reveals through the strategic lens of that era. Be specific — reference the actual data patterns. Write like a senior intelligence analyst.

Format your response EXACTLY as:
ROMANA: [conclusion]
SONG: [conclusion]
RENAISSANCE: [conclusion]
TWENTIES: [conclusion]
GOLDEN: [conclusion]
NINETIES: [conclusion]

Eras: ${eraKeys.map(k => eraLabels[k]).join(', ')}`;

  try {
    const result = await callAI(prompt, 900);
    const lines = result.split('\n').filter(l => l.trim());
    const parsed = {};
    for (const line of lines) {
      const match = line.match(/^(ROMANA|SONG|RENAISSANCE|TWENTIES|GOLDEN|NINETIES):\s*(.+)/i);
      if (match) parsed[match[1].toLowerCase()] = match[2].trim();
    }

    for (const era of eraKeys) {
      const el = document.getElementById('intel-' + era);
      const card = el?.closest('.era-intel-card');
      if (el && parsed[era]) {
        el.innerHTML = parsed[era];
        card?.classList.add('loaded');
      } else if (el) {
        el.innerHTML = '<em>No data returned for this era.</em>';
      }
    }
    eraIntelGenerated = true;
    btn.textContent = '✓ Intelligence Generated';
    btn.classList.remove('generating');
  } catch (err) {
    console.error('Era intel AI error:', err);
    btn.textContent = '✗ Generation Failed — Retry';
    btn.classList.remove('generating');
    btn.disabled = false;
  }
}

// --- LAUNCH ALL REAL DATA CHARTS ---
// Stagger to avoid overwhelming World Bank API
async function loadAllRealCharts() {
  loadGDPChart();
  await new Promise(r => setTimeout(r, 300));
  loadTradeChart();
  await new Promise(r => setTimeout(r, 300));
  loadOilChart();
}

// Trigger when new charts section scrolls into view
let realChartsLoaded = false;
const realChartObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting && !realChartsLoaded) {
      realChartsLoaded = true;
      loadAllRealCharts();
      realChartObserver.disconnect();
    }
  });
}, { threshold: 0.05 });
const gdpChartEl = document.getElementById('gdp-chart');
if (gdpChartEl) realChartObserver.observe(gdpChartEl);

// Initial calculation
calculate();
