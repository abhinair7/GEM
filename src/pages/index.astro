// --- AI ERA INTELLIGENCE FLASHCARDS ---
let eraIntelGenerated = false;
const eraIntelBtn = document.getElementById('era-intel-btn');
if (eraIntelBtn) {
  eraIntelBtn.addEventListener('click', () => generateEraIntel());
}

async function generateEraIntel() {
  if (!CEREBRAS_KEY) { alert('AI key not configured'); return; }
  const btn = document.getElementById('era-intel-btn');
  btn.disabled = true;
  btn.classList.add('generating');
  btn.textContent = '⟳ Generating Intelligence…';

  // Wait for FRED data if it hasn't loaded yet
  const dataKeys = ['dollar','gold','oil','treasury','vix','forex'];
  const hasData = dataKeys.some(k => _fullData[k] && _fullData[k].length);
  if (!hasData && _fredReady) {
    btn.textContent = '⟳ Waiting for FRED data…';
    try { await _fredReady; } catch(e) { /* fallback below */ }
    // Small extra delay for loaders to populate _fullData
    await new Promise(r => setTimeout(r, 500));
  }

  // Build dynamic data summaries from full (unfiltered) FRED data
  function summariseSeries(label, arr) {
    if (!arr || arr.length === 0) return label + ': no data available';
    const sorted = [...arr].sort((a, b) => a.year - b.year);
    const latest = sorted[sorted.length - 1];
    const earliest = sorted[0];
    const values = sorted.map(d => d.value);
    const min = Math.min(...values);
    const max = Math.max(...values);
    const avg = values.reduce((s, v) => s + v, 0) / values.length;
    const trend = latest.value > earliest.value ? 'rising' : latest.value < earliest.value ? 'falling' : 'flat';
    const pctChange = earliest.value !== 0 ? (((latest.value - earliest.value) / earliest.value) * 100).toFixed(1) : 'N/A';
    return `${label}: ${sorted.length} data points (${Math.round(earliest.year)}–${Math.round(latest.year)}). Latest: ${latest.value.toLocaleString(undefined,{maximumFractionDigits:1})} | Range: ${min.toLocaleString(undefined,{maximumFractionDigits:1})} – ${max.toLocaleString(undefined,{maximumFractionDigits:1})} | Avg: ${avg.toLocaleString(undefined,{maximumFractionDigits:1})} | Trend: ${trend} (${pctChange}% change)`;
  }

  let dollarSummary = 'Dollar Index: not yet loaded';
  if (_fullData.dollar && _fullData.dollar.length) {
    dollarSummary = 'U.S. Dollar Index (Trade-Weighted):\n  ' + summariseSeries('USD Index', _fullData.dollar);
  }
  let goldSummary = 'Gold Price: not yet loaded';
  if (_fullData.gold && _fullData.gold.length) {
    goldSummary = 'Gold Spot Price (USD/troy oz):\n  ' + summariseSeries('Gold', _fullData.gold);
  }
  let oilSummary = 'Oil Prices: not yet loaded';
  if (_fullData.oil && _fullData.oil.length) {
    oilSummary = 'Brent Crude Oil ($/barrel):\n  ' + summariseSeries('Brent Crude', _fullData.oil);
  }
  let treasurySummary = 'Treasury Spread: not yet loaded';
  if (_fullData.treasury && _fullData.treasury.length) {
    treasurySummary = '10Y-2Y Treasury Yield Spread (%):\n  ' + summariseSeries('Spread', _fullData.treasury);
  }
  let vixSummary = 'VIX: not yet loaded';
  if (_fullData.vix && _fullData.vix.length) {
    vixSummary = 'CBOE Volatility Index (VIX):\n  ' + summariseSeries('VIX', _fullData.vix);
  }
  let forexSummary = 'USD/EUR Forex: not yet loaded';
  if (_fullData.forex && _fullData.forex.length) {
    forexSummary = 'USD/EUR Exchange Rate (Alpha Vantage):\n  ' + summariseSeries('USD/EUR', _fullData.forex);
  }

  const eraKeys = ['romana', 'song', 'renaissance', 'dutch', 'golden', 'nineties'];
  const eraLabels = {
    romana: 'Pax Romana (27 BC–180 AD)',
    song: 'Song Dynasty (960–1279 AD)',
    renaissance: 'Italian Renaissance (1450–1600)',
    dutch: 'Dutch Golden Age (1580–1672)',
    golden: 'Golden Age USA (1950s)',
    nineties: 'Information Age (1990s)',
  };

  const timestamp = new Date().toISOString();
  const prompt = `You are a senior geopolitical intelligence analyst for the Geopolitical Equilibrium Model (GEM). Timestamp: ${timestamp}

Below is LIVE economic data fetched moments ago from the Federal Reserve Economic Data (FRED) API and Alpha Vantage authenticated API — six indicators covering currency strength, safe-haven demand, energy markets, recession risk, market volatility, and forex dynamics. Analyse these EXACT numbers — do not use generic or memorised data:

1. ${dollarSummary}

2. ${goldSummary}

3. ${oilSummary}

4. ${treasurySummary}

5. ${vixSummary}

6. ${forexSummary}

For EACH of the 6 historical eras below, write a 2–3 sentence analytical conclusion connecting what this SPECIFIC modern economic data reveals through the strategic lens of that era. Reference the actual numbers, trends, and percentage changes above. Each era's analysis must be distinct and non-generic.

Format your response EXACTLY as:
ROMANA: [conclusion]
SONG: [conclusion]
RENAISSANCE: [conclusion]
DUTCH: [conclusion]
GOLDEN: [conclusion]
NINETIES: [conclusion]

Eras: ${eraKeys.map(k => eraLabels[k]).join(', ')}`;

  try {
    const result = await callAI(prompt, 900);
    const lines = result.split('\n').filter(l => l.trim());
    const parsed = {};
    for (const line of lines) {
      const match = line.match(/^(ROMANA|SONG|RENAISSANCE|DUTCH|GOLDEN|NINETIES):\s*(.+)/i);
      if (match) parsed[match[1].toLowerCase()] = match[2].trim();
    }

    for (const era of eraKeys) {
      const el = document.getElementById('intel-' + era);
      const card = el?.closest('.era-intel-card');
      if (el && parsed[era]) {
        el.innerHTML = parsed[era];
        card?.classList.add('loaded');
      } else if (el) {
        el.innerHTML = '<em>No data returned for this era.</em>';
      }
    }
    eraIntelGenerated = true;
    btn.textContent = '✓ Intelligence Generated';
    btn.classList.remove('generating');
  } catch (err) {
    console.error('Era intel AI error:', err);
    btn.textContent = '✗ Generation Failed — Retry';
    btn.classList.remove('generating');
    btn.disabled = false;
  }
}

// --- RESPONSIVE CANVAS SIZING (DPR-AWARE) ---
// Size canvas to container, render at native device resolution for crisp charts
function fitCanvasToContainer(canvas) {
  const parent = canvas.parentElement;
  if (!parent) return;
  const dpr = window.devicePixelRatio || 1;
  const style = getComputedStyle(parent);
  const padL = parseFloat(style.paddingLeft) || 0;
  const padR = parseFloat(style.paddingRight) || 0;
  const cssW = Math.floor(parent.clientWidth - padL - padR);
  // Store original HTML attribute dimensions on first call
  if (!canvas._origW) {
    canvas._origW = parseInt(canvas.getAttribute('width')) || canvas.width;
    canvas._origH = parseInt(canvas.getAttribute('height')) || canvas.height;
  }
  const ratio = canvas._origH / canvas._origW;
  const w = Math.min(cssW, canvas._origW);
  const h = Math.round(w * ratio);
  // Set internal resolution to DPR multiple for crisp rendering
  canvas.width = w * dpr;
  canvas.height = h * dpr;
  // Set CSS display size
  canvas.style.width = w + 'px';
  canvas.style.height = h + 'px';
  // Scale context so drawing code uses CSS pixels
  const ctx = canvas.getContext('2d');
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  // Store CSS dimensions for draw functions
  canvas._cssW = w;
  canvas._cssH = h;
}
document.querySelectorAll('canvas').forEach(fitCanvasToContainer);

// --- LAUNCH ALL REAL DATA CHARTS (live fetch from serverless API) ---
var SERIES_MAP = {
  DTWEXBGS:      function(d, s) { loadDollarChart(d, s); },
  PCU21222122:   function(d, s) { loadGoldChart(d, s); },
  DCOILBRENTEU:  function(d, s) { loadOilChart(d, s); },
  T10Y2Y:        function(d, s) { loadTreasuryChart(d, s); },
  VIXCLS:        function(d, s) { loadVIXChart(d, s); },
  DEXUSEU:       function(d, s) { loadForexChart(d, s); }
};

function loadAllRealCharts() {
  var ids = Object.keys(SERIES_MAP).join(',');
  ['dollar','gold','oil','treasury','vix','forex'].forEach(function(k, i) {
    var statusId = ['dollar','gold','oil','treasury','vix','forex'][i] + '-status';
    setStatus(statusId, '⟳ Fetching live FRED data…', '');
  });
  _fredReady = fetch('/api/fred?series=' + ids)
    .then(function(r) { return r.json(); })
    .then(function(json) {
      var src = json.fallback ? 'cached (build-time)' : 'live';
      var srcIcon = json.fallback ? '⟳' : '✦';
      if (json.data) {
        Object.keys(SERIES_MAP).forEach(function(id) {
          if (json.data[id] && json.data[id].length) {
            // Find latest data point date for display
            var sorted = json.data[id].slice().sort(function(a,b) { return b.year - a.year; });
            var latestDate = sorted[0] && sorted[0].date ? sorted[0].date : 'unknown';
            SERIES_MAP[id](json.data[id], src + ' — latest: ' + latestDate);
          }
        });
      }
      if (json.errors && json.errors.length) {
        console.warn('[FRED] Some series had errors:', json.errors);
        json.errors.forEach(function(e) {
          // Show error on specific chart
          var parts = e.split(':');
          var failedId = parts[0] && parts[0].trim();
          var fallbackKey = { DTWEXBGS:'dollar', PCU21222122:'gold', DCOILBRENTEU:'oil', T10Y2Y:'treasury', VIXCLS:'vix', DEXUSEU:'forex' };
          var k = fallbackKey[failedId];
          if (k) setStatus(k + '-status', '⚠ ' + e, 'error');
        });
      }
      if (json.fallback) {
        console.warn('[FRED] Using cached build-time data — live FRED fetch unavailable');
      }
    })
    .catch(function(err) {
      console.error('[FRED] Live fetch failed:', err);
      ['dollar','gold','oil','treasury','vix','forex'].forEach(function(k) {
        setStatus(k + '-status', '✗ Live data unavailable — check connection', 'error');
      });
    });
}

// Fetch live data immediately
try { loadAllRealCharts(); } catch(e) { console.error('Chart load error:', e); }

// Initial calculation
calculate();

