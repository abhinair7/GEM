// =========================================================
// RADAR CHART
// =========================================================
function drawRadar(input, matchedEra) {
  const canvas = document.getElementById('radar-chart');
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  const ctx = canvas.getContext('2d');
  const W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  const cx = W/2, cy = H/2 + 10, R = Math.min(W,H)*0.35;
  ctx.clearRect(0,0,W,H);
  const labels = ['Trade', 'Politics', 'Security', 'Benefit'];
  const angles = labels.map((_, i) => (Math.PI*2*i/4) - Math.PI/2);
  for (let r = 0.2; r <= 1; r += 0.2) {
    ctx.beginPath();
    angles.forEach((a, i) => { const x = cx + Math.cos(a)*R*r, y = cy + Math.sin(a)*R*r; i===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y); });
    ctx.closePath(); ctx.strokeStyle = 'rgba(0,0,0,0.06)'; ctx.lineWidth = 1; ctx.stroke();
  }
  angles.forEach((a, i) => {
    ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx+Math.cos(a)*R*1.1, cy+Math.sin(a)*R*1.1);
    ctx.strokeStyle = 'rgba(0,0,0,0.08)'; ctx.stroke();
    const lx = cx + Math.cos(a)*R*1.22, ly = cy + Math.sin(a)*R*1.22;
    ctx.font = '500 10px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(labels[i].toUpperCase(), lx, ly);
  });
  const ep = eraProfiles[matchedEra];
  const eVals = [ep.trade, ep.politics, ep.security, ep.benefit];
  ctx.beginPath();
  eVals.forEach((v, i) => { const x = cx+Math.cos(angles[i])*R*v, y = cy+Math.sin(angles[i])*R*v; i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
  ctx.closePath(); ctx.fillStyle = 'rgba(26,28,27,0.08)'; ctx.fill();
  ctx.strokeStyle = 'rgba(26,28,27,0.4)'; ctx.lineWidth = 1.5; ctx.stroke();
  const uVals = [input.trade, input.politics, input.security, input.benefit];
  ctx.beginPath();
  uVals.forEach((v, i) => { const x = cx+Math.cos(angles[i])*R*v, y = cy+Math.sin(angles[i])*R*v; i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
  ctx.closePath(); ctx.fillStyle = 'rgba(197,160,89,0.15)'; ctx.fill();
  ctx.strokeStyle = '#c5a059'; ctx.lineWidth = 2; ctx.stroke();
  uVals.forEach((v, i) => { ctx.beginPath(); ctx.arc(cx+Math.cos(angles[i])*R*v, cy+Math.sin(angles[i])*R*v, 4, 0, Math.PI*2); ctx.fillStyle = '#c5a059'; ctx.fill(); });
  eVals.forEach((v, i) => { ctx.beginPath(); ctx.arc(cx+Math.cos(angles[i])*R*v, cy+Math.sin(angles[i])*R*v, 3, 0, Math.PI*2); ctx.fillStyle = '#1a1c1b'; ctx.fill(); });
  ctx.font = '500 10px Inter'; ctx.textAlign = 'left';
  ctx.fillStyle = '#c5a059'; ctx.fillRect(20, H-30, 10, 10); ctx.fillStyle = '#44474e'; ctx.fillText('Your Input', 36, H-21);
  ctx.fillStyle = '#1a1c1b'; ctx.fillRect(120, H-30, 10, 10); ctx.fillStyle = '#44474e'; ctx.fillText('Matched Era', 136, H-21);
}

// =========================================================
// SCATTER CHART — PCA PROJECTION
// =========================================================
function pcaProject(profiles, inputPoint) {
  // Gather all points as 4D vectors: [trade, politics, security, benefit]
  const keys = Object.keys(profiles);
  const raw = keys.map(k => [profiles[k].trade, profiles[k].politics, profiles[k].security, profiles[k].benefit]);
  raw.push([inputPoint.trade, inputPoint.politics, inputPoint.security, inputPoint.benefit]);
  const n = raw.length, d = 4;
  // Compute mean per dimension
  const mean = Array(d).fill(0);
  raw.forEach(p => p.forEach((v, i) => mean[i] += v));
  mean.forEach((_, i) => mean[i] /= n);
  // Center
  const centered = raw.map(p => p.map((v, i) => v - mean[i]));
  // Covariance matrix
  const cov = Array.from({length: d}, () => Array(d).fill(0));
  centered.forEach(p => { for (let i=0;i<d;i++) for (let j=0;j<d;j++) cov[i][j] += p[i]*p[j]; });
  for (let i=0;i<d;i++) for (let j=0;j<d;j++) cov[i][j] /= (n-1);
  // Power iteration for eigenvector
  function topEigen(mat) {
    let v = [1, 0.7, 0.4, 0.1];
    let eigenval = 0;
    for (let iter=0;iter<200;iter++) {
      const nv = Array(d).fill(0);
      for (let i=0;i<d;i++) for (let j=0;j<d;j++) nv[i] += mat[i][j]*v[j];
      eigenval = Math.sqrt(nv.reduce((s,x)=>s+x*x,0));
      if (eigenval === 0) break;
      v = nv.map(x => x/eigenval);
    }
    return { vec: v, val: eigenval };
  }
  const e1 = topEigen(cov);
  // Deflate for second component
  const cov2 = cov.map((row,i) => row.map((val,j) => val - e1.val * e1.vec[i] * e1.vec[j]));
  const e2 = topEigen(cov2);
  // Project
  return centered.map(p => ({
    x: p.reduce((s,v,i) => s + v * e1.vec[i], 0),
    y: p.reduce((s,v,i) => s + v * e2.vec[i], 0)
  }));
}

function drawScatter(input, matchedEra) {
  const canvas = document.getElementById('scatter-chart');
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  const ctx = canvas.getContext('2d');
  const W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  const pad = { top: 55, right: 50, bottom: 55, left: 60 };
  ctx.clearRect(0,0,W,H);

  // Run PCA
  const eraKeys = Object.keys(eraProfiles);
  const projected = pcaProject(eraProfiles, input); // last point = user
  const eraPoints = projected.slice(0, eraKeys.length);
  const userPoint = projected[projected.length - 1];

  // Compute bounds with padding
  const allX = projected.map(p => p.x), allY = projected.map(p => p.y);
  let minX = Math.min(...allX), maxX = Math.max(...allX);
  let minY = Math.min(...allY), maxY = Math.max(...allY);
  const rangeX = maxX - minX || 1, rangeY = maxY - minY || 1;
  const marginFactor = 0.15;
  minX -= rangeX * marginFactor; maxX += rangeX * marginFactor;
  minY -= rangeY * marginFactor; maxY += rangeY * marginFactor;

  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  function toCanvas(pt) {
    return {
      x: pad.left + ((pt.x - minX) / (maxX - minX)) * cw,
      y: pad.top + ch - ((pt.y - minY) / (maxY - minY)) * ch
    };
  }

  // Background grid
  ctx.strokeStyle = 'rgba(0,0,0,0.06)'; ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const gx = pad.left + (i/4) * cw;
    const gy = pad.top + (i/4) * ch;
    ctx.beginPath(); ctx.moveTo(gx, pad.top); ctx.lineTo(gx, pad.top + ch); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(pad.left, gy); ctx.lineTo(pad.left + cw, gy); ctx.stroke();
  }

  // Axes
  ctx.strokeStyle = 'rgba(0,0,0,0.15)'; ctx.lineWidth = 1.5;
  ctx.beginPath(); ctx.moveTo(pad.left, pad.top + ch); ctx.lineTo(pad.left + cw, pad.top + ch); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, pad.top + ch); ctx.lineTo(pad.left, pad.top); ctx.stroke();

  // Axis labels
  ctx.font = '500 10px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
  ctx.fillText('PC1 — TRADE OPENNESS vs. BENEFIT CONCENTRATION', pad.left + cw/2, H - 10);
  ctx.save(); ctx.translate(14, pad.top + ch/2); ctx.rotate(-Math.PI/2);
  ctx.fillText('PC2 — STABILITY & GOVERNANCE', 0, 0); ctx.restore();

  // Dashed connection lines from user to each era
  const up = toCanvas(userPoint);
  eraKeys.forEach((k, i) => {
    const pt = toCanvas(eraPoints[i]);
    ctx.beginPath(); ctx.moveTo(pt.x, pt.y); ctx.lineTo(up.x, up.y);
    ctx.setLineDash(k === matchedEra ? [] : [4,4]);
    ctx.strokeStyle = k === matchedEra ? 'rgba(197,160,89,0.5)' : 'rgba(0,0,0,0.06)';
    ctx.lineWidth = k === matchedEra ? 2 : 1; ctx.stroke();
    ctx.setLineDash([]);
  });

  // Era dots
  eraKeys.forEach((k, i) => {
    const pt = toCanvas(eraPoints[i]);
    const isMatch = k === matchedEra;
    const r = isMatch ? 11 : 8;
    // Shadow for matched
    if (isMatch) {
      ctx.beginPath(); ctx.arc(pt.x, pt.y, r + 4, 0, Math.PI*2);
      ctx.fillStyle = 'rgba(197,160,89,0.12)'; ctx.fill();
    }
    // Dot
    ctx.beginPath(); ctx.arc(pt.x, pt.y, r, 0, Math.PI*2);
    ctx.fillStyle = isMatch ? eraColors[k] : '#b0b5ac'; ctx.fill();
    if (isMatch) { ctx.strokeStyle = eraColors[k]; ctx.lineWidth = 2.5; ctx.stroke(); }
    // Label
    ctx.font = isMatch ? '600 12px Inter' : '400 11px Inter';
    ctx.fillStyle = isMatch ? '#1a1c1b' : '#74796e';
    ctx.textAlign = 'center';
    // Offset label to avoid overlapping the dot
    const labelY = pt.y - r - 8;
    ctx.fillText(eraInfo[k].name, pt.x, labelY);
  });

  // User dot — gold with glow
  ctx.beginPath(); ctx.arc(up.x, up.y, 14, 0, Math.PI*2);
  ctx.fillStyle = 'rgba(197,160,89,0.15)'; ctx.fill();
  ctx.beginPath(); ctx.arc(up.x, up.y, 9, 0, Math.PI*2);
  ctx.fillStyle = '#c5a059'; ctx.fill();
  ctx.strokeStyle = '#8b6914'; ctx.lineWidth = 2.5; ctx.stroke();
  ctx.font = '700 12px Inter'; ctx.fillStyle = '#8b6914'; ctx.textAlign = 'center';
  ctx.fillText('YOU', up.x, up.y - 18);
}

// =========================================================
// LIFECYCLE CURVES
// =========================================================
// =========================================================
// LIFECYCLE — STACKED AREA CHART
// =========================================================
function drawLifecycle() {
  const canvas = document.getElementById('lifecycle-chart');
  if (!canvas._cssW) fitCanvasToContainer(canvas);
  const ctx = canvas.getContext('2d');
  const W = canvas._cssW || canvas.width, H = canvas._cssH || canvas.height;
  const pad = { top: 30, right: 140, bottom: 50, left: 60 };
  ctx.clearRect(0,0,W,H);
  const curves = {
    romana: { color:'#8b6914', fill:'rgba(139,105,20,0.12)', pts: [[0,0.1],[10,0.3],[25,0.6],[40,0.85],[55,0.95],[70,0.9],[80,0.7],[90,0.4],[100,0.15]], label:'Pax Romana' },
    song: { color:'#2d6e5f', fill:'rgba(45,110,95,0.10)', pts: [[0,0.05],[15,0.25],[30,0.55],[45,0.8],[60,0.92],[70,0.88],[80,0.65],[90,0.3],[100,0.08]], label:'Song Dynasty' },
    renaissance: { color:'#c5a059', fill:'rgba(197,160,89,0.10)', pts: [[0,0.08],[10,0.35],[20,0.65],[35,0.9],[50,0.98],[60,0.85],[75,0.5],[90,0.2],[100,0.05]], label:'Renaissance' },
    dutch: { color:'#e67e22', fill:'rgba(230,126,34,0.10)', pts: [[0,0.08],[10,0.25],[20,0.5],[35,0.75],[50,0.88],[60,0.95],[70,0.92],[80,0.78],[90,0.5],[100,0.2]], label:'Dutch Republic' },
    golden: { color:'#44474e', fill:'rgba(68,71,78,0.10)', pts: [[0,0.1],[10,0.3],[25,0.55],[40,0.75],[55,0.88],[70,0.92],[80,0.85],[90,0.7],[100,0.55]], label:'1950s Golden' },
    nineties: { color:'#1a1c1b', fill:'rgba(26,28,27,0.08)', pts: [[0,0.2],[10,0.4],[25,0.6],[40,0.8],[55,0.92],[65,0.95],[75,0.88],[85,0.72],[100,0.6]], label:'1990s Info Age' },
  };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  // Grid
  ctx.strokeStyle = 'rgba(0,0,0,0.08)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let v = 0; v <= 1; v += 0.25) {
    const y = H - pad.bottom - v * ch;
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W-pad.right, y); ctx.strokeStyle = 'rgba(0,0,0,0.03)'; ctx.stroke();
    ctx.fillText((v*100).toFixed(0)+'%', pad.left-8, y+3);
  }
  ctx.textAlign = 'center'; ctx.fillStyle = '#a3a8a0';
  ['INCEPTION','25%','PEAK','75%','DECLINE'].forEach((l,i) => { ctx.fillText(l, pad.left + (i/4)*cw, H-pad.bottom+20); });
  ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.fillText('% OF ERA DURATION', (pad.left + W - pad.right)/2, H-8);
  // Draw filled areas + lines
  function interpY(pts, xPct) {
    for (let i = 0; i < pts.length - 1; i++) {
      if (xPct >= pts[i][0] && xPct <= pts[i+1][0]) {
        const t = (xPct - pts[i][0]) / (pts[i+1][0] - pts[i][0]);
        return pts[i][1] + t * (pts[i+1][1] - pts[i][1]);
      }
    }
    return pts[pts.length-1][1];
  }
  Object.values(curves).forEach(era => {
    // Filled area
    ctx.beginPath();
    for (let pct = 0; pct <= 100; pct += 0.5) {
      const x = pad.left + (pct/100)*cw;
      const y = H - pad.bottom - interpY(era.pts, pct)*ch;
      pct === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.lineTo(pad.left + cw, H - pad.bottom);
    ctx.lineTo(pad.left, H - pad.bottom);
    ctx.closePath();
    ctx.fillStyle = era.fill; ctx.fill();
    // Stroke line
    ctx.beginPath();
    for (let pct = 0; pct <= 100; pct += 0.5) {
      const x = pad.left + (pct/100)*cw;
      const y = H - pad.bottom - interpY(era.pts, pct)*ch;
      pct === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.strokeStyle = era.color; ctx.lineWidth = 2; ctx.stroke();
    // Peak dot
    const peak = era.pts.reduce((a,b) => b[1] > a[1] ? b : a);
    const px = pad.left + (peak[0]/100)*cw, py = H - pad.bottom - peak[1]*ch;
    ctx.beginPath(); ctx.arc(px, py, 4, 0, Math.PI*2);
    ctx.fillStyle = era.color; ctx.fill();
  });
  // Legend on right
  let ly = pad.top + 10;
  Object.values(curves).forEach(era => {
    ctx.fillStyle = era.color; ctx.fillRect(W-pad.right+16, ly, 12, 12);
    ctx.fillStyle = era.fill; ctx.fillRect(W-pad.right+16, ly, 12, 12);
    ctx.strokeStyle = era.color; ctx.lineWidth = 1.5; ctx.strokeRect(W-pad.right+16, ly, 12, 12);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#44474e'; ctx.textAlign = 'left';
    ctx.fillText(era.label, W-pad.right+34, ly+10);
    ly += 22;
  });
}

