  sliders.trade.value=74; sliders.politics.value=88; sliders.security.value=92; sliders.benefit.value=22; calculate();
});

// =========================================================
// RADAR CHART
// =========================================================
function drawRadar(input, matchedEra) {
  const canvas = document.getElementById('radar-chart');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const cx = W/2, cy = H/2 + 10, R = Math.min(W,H)*0.35;
  ctx.clearRect(0,0,W,H);
  const labels = ['Trade', 'Politics', 'Security', 'Benefit'];
  const angles = labels.map((_, i) => (Math.PI*2*i/4) - Math.PI/2);
  for (let r = 0.2; r <= 1; r += 0.2) {
    ctx.beginPath();
    angles.forEach((a, i) => { const x = cx + Math.cos(a)*R*r, y = cy + Math.sin(a)*R*r; i===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y); });
    ctx.closePath(); ctx.strokeStyle = 'rgba(0,0,0,0.06)'; ctx.lineWidth = 1; ctx.stroke();
  }
  angles.forEach((a, i) => {
    ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx+Math.cos(a)*R*1.1, cy+Math.sin(a)*R*1.1);
    ctx.strokeStyle = 'rgba(0,0,0,0.08)'; ctx.stroke();
    const lx = cx + Math.cos(a)*R*1.22, ly = cy + Math.sin(a)*R*1.22;
    ctx.font = '500 10px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(labels[i].toUpperCase(), lx, ly);
  });
  const ep = eraProfiles[matchedEra];
  const eVals = [ep.trade, ep.politics, ep.security, ep.benefit];
  ctx.beginPath();
  eVals.forEach((v, i) => { const x = cx+Math.cos(angles[i])*R*v, y = cy+Math.sin(angles[i])*R*v; i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
  ctx.closePath(); ctx.fillStyle = 'rgba(26,28,27,0.08)'; ctx.fill();
  ctx.strokeStyle = 'rgba(26,28,27,0.4)'; ctx.lineWidth = 1.5; ctx.stroke();
  const uVals = [input.trade, input.politics, input.security, input.benefit];
  ctx.beginPath();
  uVals.forEach((v, i) => { const x = cx+Math.cos(angles[i])*R*v, y = cy+Math.sin(angles[i])*R*v; i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
  ctx.closePath(); ctx.fillStyle = 'rgba(197,160,89,0.15)'; ctx.fill();
  ctx.strokeStyle = '#c5a059'; ctx.lineWidth = 2; ctx.stroke();
  uVals.forEach((v, i) => { ctx.beginPath(); ctx.arc(cx+Math.cos(angles[i])*R*v, cy+Math.sin(angles[i])*R*v, 4, 0, Math.PI*2); ctx.fillStyle = '#c5a059'; ctx.fill(); });
  eVals.forEach((v, i) => { ctx.beginPath(); ctx.arc(cx+Math.cos(angles[i])*R*v, cy+Math.sin(angles[i])*R*v, 3, 0, Math.PI*2); ctx.fillStyle = '#1a1c1b'; ctx.fill(); });
  ctx.font = '500 10px Inter'; ctx.textAlign = 'left';
  ctx.fillStyle = '#c5a059'; ctx.fillRect(20, H-30, 10, 10); ctx.fillStyle = '#44474e'; ctx.fillText('Your Input', 36, H-21);
  ctx.fillStyle = '#1a1c1b'; ctx.fillRect(120, H-30, 10, 10); ctx.fillStyle = '#44474e'; ctx.fillText('Matched Era', 136, H-21);
}

// =========================================================
// SCATTER CHART
// =========================================================
function project2D(p) { return { x: (p.trade - p.benefit + 1) / 2, y: (p.politics + p.security) / 2 }; }

function drawScatter(input, matchedEra) {
  const canvas = document.getElementById('scatter-chart');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height, pad = 60;
  ctx.clearRect(0,0,W,H);
  ctx.strokeStyle = 'rgba(0,0,0,0.08)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad, H-pad); ctx.lineTo(W-pad, H-pad); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad, H-pad); ctx.lineTo(pad, pad); ctx.stroke();
  ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.textAlign = 'center';
  ctx.fillText('TRADE–BENEFIT AXIS (OPENNESS)', W/2, H-15);
  ctx.save(); ctx.translate(15, H/2); ctx.rotate(-Math.PI/2);
  ctx.fillText('STABILITY AXIS (POLITICS + SECURITY)', 0, 0); ctx.restore();
  for (let i = 0.2; i <= 0.8; i += 0.2) {
    const gx = pad + i*(W-2*pad), gy = H - pad - i*(H-2*pad);
    ctx.beginPath(); ctx.moveTo(gx, H-pad); ctx.lineTo(gx, pad); ctx.strokeStyle='rgba(0,0,0,0.03)'; ctx.stroke();
    ctx.beginPath(); ctx.moveTo(pad, gy); ctx.lineTo(W-pad, gy); ctx.stroke();
  }
  function toCanvas(pt) { return { x: pad + pt.x*(W-2*pad), y: H - pad - pt.y*(H-2*pad) }; }
  const eraKeys = Object.keys(eraProfiles);
  eraKeys.forEach(k => {
    const pt = toCanvas(project2D(eraProfiles[k]));
    const userPt = toCanvas(project2D(input));
    ctx.beginPath(); ctx.moveTo(pt.x, pt.y); ctx.lineTo(userPt.x, userPt.y);
    ctx.strokeStyle = k === matchedEra ? 'rgba(197,160,89,0.3)' : 'rgba(0,0,0,0.04)';
    ctx.lineWidth = k === matchedEra ? 1.5 : 1; ctx.stroke();
    const r = k === matchedEra ? 8 : 6;
    ctx.beginPath(); ctx.arc(pt.x, pt.y, r, 0, Math.PI*2);
    ctx.fillStyle = k === matchedEra ? eraColors[k] : '#a3a8a0'; ctx.fill();
    if (k === matchedEra) { ctx.strokeStyle = eraColors[k]; ctx.lineWidth = 2; ctx.stroke(); }
    ctx.font = k===matchedEra ? '600 10px Inter' : '400 9px Inter';
    ctx.fillStyle = k===matchedEra ? '#1a1c1b' : '#74796e';
    ctx.textAlign = 'center'; ctx.fillText(eraInfo[k].name, pt.x, pt.y - r - 6);
  });
  const up = toCanvas(project2D(input));
  ctx.beginPath(); ctx.arc(up.x, up.y, 7, 0, Math.PI*2);
  ctx.fillStyle = '#c5a059'; ctx.fill(); ctx.strokeStyle = '#8b6914'; ctx.lineWidth = 2; ctx.stroke();
  ctx.font = '600 10px Inter'; ctx.fillStyle = '#8b6914'; ctx.textAlign = 'center'; ctx.fillText('YOU', up.x, up.y - 14);
}

