// =========================================================
(function() {
  // Add timeout warnings for AI panels
  var aiPanels = [
    { badge: 'playbook-badge', body: 'playbook-grid', timeout: 30000, name: 'Playbook' },
    { badge: 'briefing-badge', body: 'ai-briefing-body', timeout: 30000, name: 'Briefing' },
    { badge: 'fragility-badge', body: 'ai-fragility-body', timeout: 30000, name: 'Risk Assessment' }
  ];

  aiPanels.forEach(function(panel) {
    var badge = document.getElementById(panel.badge);
    if (!badge) return;
    // Watch for generating state
    var observer = new MutationObserver(function() {
      if (badge.classList.contains('generating')) {
        clearTimeout(badge._aiTimeout);
        badge._aiTimeout = setTimeout(function() {
          if (badge.classList.contains('generating')) {
            badge.textContent = panel.name + ' — Taking longer than expected…';
          }
        }, panel.timeout);
      }
    });
    observer.observe(badge, { attributes: true, attributeFilter: ['class'] });
  });
})();
