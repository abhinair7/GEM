---
import BaseLayout from '../layouts/BaseLayout.astro';
import { eraCards, historicalData } from '../data/eras';
import '../styles/global.css';

export const prerender = true; // This page is static (hybrid mode)

const CEREBRAS_API_KEY = import.meta.env.PUBLIC_CEREBRAS_API_KEY || '';

const eraArtifacts: Record<string, string> = {
  romana: `<svg class="era-artifact-svg" viewBox="0 0 60 120" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M30 4L36 42L30 48L24 42Z" fill="currentColor" opacity="0.25"/>
    <path d="M30 4L36 42L30 48L24 42Z"/>
    <line x1="18" y1="50" x2="42" y2="50"/>
    <line x1="20" y1="48" x2="20" y2="52"/>
    <line x1="40" y1="48" x2="40" y2="52"/>
    <rect x="26" y="52" width="8" height="22" rx="2"/>
    <line x1="26" y1="58" x2="34" y2="58"/>
    <line x1="26" y1="64" x2="34" y2="64"/>
    <circle cx="30" cy="80" r="5"/>
    <circle cx="30" cy="80" r="2" fill="currentColor" opacity="0.3"/>
  </svg>`,

  song: `<svg class="era-artifact-svg" viewBox="0 0 60 120" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <ellipse cx="30" cy="8" rx="5" ry="2.5"/>
    <line x1="25" y1="8" x2="25" y2="72"/>
    <line x1="35" y1="8" x2="35" y2="72"/>
    <line x1="25" y1="30" x2="35" y2="30"/>
    <line x1="25" y1="50" x2="35" y2="50"/>
    <path d="M25 72 Q24 80 22 90 Q20 100 18 105" stroke-width="1.5"/>
    <path d="M35 72 Q36 80 38 90 Q40 100 42 105" stroke-width="1.5"/>
    <path d="M30 72 Q30 85 30 100 Q30 108 30 112" stroke-width="2"/>
    <path d="M18 105 Q24 108 30 112 Q36 108 42 105" fill="currentColor" opacity="0.15"/>
  </svg>`,

  renaissance: `<svg class="era-artifact-svg" viewBox="0 0 70 120" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="35" cy="10" r="5"/>
    <circle cx="35" cy="10" r="2" fill="currentColor" opacity="0.3"/>
    <line x1="35" y1="15" x2="12" y2="105"/>
    <line x1="35" y1="15" x2="58" y2="105"/>
    <path d="M22 65 Q35 58 48 65" stroke-dasharray="3 2"/>
    <circle cx="12" cy="105" r="2" fill="currentColor" opacity="0.4"/>
    <path d="M56 105 Q58 108 58 105 Q58 102 60 105" stroke-width="0.8"/>
    <circle cx="35" cy="10" r="8" stroke-dasharray="2 3" opacity="0.4"/>
  </svg>`,

  dutch: `<svg class="era-artifact-svg" viewBox="0 0 80 120" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
    <!-- VOC Ship Hull -->
    <path d="M10 75 Q15 85 40 88 Q65 85 70 75" stroke-width="1.5"/>
    <path d="M10 75 L15 70 Q40 65 65 70 L70 75" fill="currentColor" opacity="0.08"/>
    <!-- Mast -->
    <line x1="40" y1="20" x2="40" y2="75" stroke-width="1.5"/>
    <!-- Sails -->
    <path d="M40 22 Q55 30 52 42 L40 42" fill="currentColor" opacity="0.15" stroke-width="1"/>
    <path d="M40 22 Q55 30 52 42 L40 42" stroke-width="1"/>
    <path d="M40 44 Q58 52 54 62 L40 62" fill="currentColor" opacity="0.10" stroke-width="1"/>
    <path d="M40 44 Q58 52 54 62 L40 62" stroke-width="1"/>
    <!-- Flag -->
    <path d="M40 18 L52 22 L40 26" fill="currentColor" opacity="0.3"/>
    <!-- Rigging -->
    <line x1="40" y1="22" x2="18" y2="68" stroke-dasharray="2 2" opacity="0.35"/>
    <line x1="40" y1="22" x2="62" y2="68" stroke-dasharray="2 2" opacity="0.35"/>
    <!-- Waves -->
    <path d="M5 90 Q15 86 25 90 Q35 94 45 90 Q55 86 65 90 Q75 94 80 90" opacity="0.3"/>
    <path d="M8 96 Q18 92 28 96 Q38 100 48 96 Q58 92 68 96" opacity="0.2"/>
    <!-- VOC monogram -->
    <text x="40" y="110" font-family="serif" font-size="12" font-weight="700" fill="currentColor" opacity="0.4" text-anchor="middle" stroke="none">VOC</text>
  </svg>`,

  golden: `<svg class="era-artifact-svg" viewBox="0 0 90 90" fill="none" stroke="currentColor" stroke-width="1.2">
    <circle cx="45" cy="45" r="5" fill="currentColor" opacity="0.35"/>
    <circle cx="45" cy="45" r="2" fill="currentColor" opacity="0.6"/>
    <ellipse cx="45" cy="45" rx="35" ry="12"/>
    <ellipse cx="45" cy="45" rx="35" ry="12" transform="rotate(60 45 45)"/>
    <ellipse cx="45" cy="45" rx="35" ry="12" transform="rotate(120 45 45)"/>
    <circle cx="80" cy="45" r="3" fill="currentColor" opacity="0.5"/>
    <circle cx="27" cy="75" r="3" fill="currentColor" opacity="0.5"/>
    <circle cx="27" cy="15" r="3" fill="currentColor" opacity="0.5"/>
  </svg>`,

  nineties: `<svg class="era-artifact-svg" viewBox="0 0 90 90" fill="none" stroke="currentColor" stroke-width="1">
    <circle cx="45" cy="45" r="32"/>
    <ellipse cx="45" cy="45" rx="32" ry="12"/>
    <ellipse cx="45" cy="45" rx="12" ry="32"/>
    <path d="M13 45 Q29 38 45 45 Q61 52 77 45" opacity="0.4"/>
    <circle cx="45" cy="13" r="3.5" fill="currentColor" opacity="0.5" stroke="none"/>
    <circle cx="72" cy="58" r="3.5" fill="currentColor" opacity="0.5" stroke="none"/>
    <circle cx="20" cy="62" r="3.5" fill="currentColor" opacity="0.5" stroke="none"/>
    <circle cx="55" cy="30" r="2.5" fill="currentColor" opacity="0.35" stroke="none"/>
    <circle cx="32" cy="35" r="2.5" fill="currentColor" opacity="0.35" stroke="none"/>
    <line x1="45" y1="13" x2="55" y2="30" stroke-dasharray="2 2" opacity="0.4"/>
    <line x1="55" y1="30" x2="72" y2="58" stroke-dasharray="2 2" opacity="0.4"/>
    <line x1="32" y1="35" x2="20" y2="62" stroke-dasharray="2 2" opacity="0.4"/>
    <line x1="32" y1="35" x2="45" y2="13" stroke-dasharray="2 2" opacity="0.4"/>
  </svg>`
};
---

<BaseLayout title="GEM — Geopolitical Equilibrium Model">

<div class="grid-overlay"></div>

<!-- Navigation -->
<nav>
  <div class="nav-brand">G<span>.</span>E<span>.</span>M</div>
  <ul class="nav-links">
    <li><a href="#splash">Origin</a></li>
    <li><a href="#thesis">Thesis</a></li>
    <li><a href="#livefeed">Live Feed</a></li>
    <li><a href="#eras">Eras</a></li>
    <li><a href="#simulation">Simulate</a></li>
    <li><a href="#analysis">Analysis</a></li>
    <li><a href="#era-intel">Intelligence</a></li>
  </ul>
  <div class="nav-status"><div class="status-dot"></div> Model Active</div>
</nav>

<!-- Splash — Architects of Prosperity  +  Reveal -->
<div class="splash" id="splash">
  <!-- Reveal layer — sits behind the curtain halves -->
  <div class="splash-reveal">
    <div class="splash-reveal-inner">
      <div class="splash-reveal-overline">Geopolitical Equilibrium Model / v3.2</div>
      <div class="splash-reveal-rule"></div>
      <h1 class="splash-reveal-title">Six empires cracked<br>the same code.<br>I <em>reverse-engineered</em> it.</h1>
      <p class="splash-reveal-subtitle">The blueprint behind every golden age in recorded history — distilled into four variables, mapped against today's conflicts, and delivered as a strategic playbook you can actually use.</p>
    </div>
    <div class="splash-reveal-scroll"><div class="splash-reveal-scroll-line"></div> Scroll to explore</div>
  </div>
  <!-- Curtain halves — single img clipped, zero seam -->
  <div class="splash-half splash-left"><img src="/architects.png" alt="" class="splash-img" /></div>
  <div class="splash-half splash-right"><img src="/architects.png" alt="" class="splash-img" /></div>
  <div class="splash-vignette"></div>
  <div class="splash-title-wrap">
    <h1 class="splash-title">The Architects<br>of Prosperity</h1>
    <div class="splash-scroll-cue"><div class="splash-scroll-line"></div> Scroll to enter</div>
  </div>
  <!-- 3D title — visible on mobile only -->
  <div class="splash-orbit">
    <span class="splash-orbit-title">
      <span class="splash-orbit-line1">The Architects</span>
      <span class="splash-orbit-line2">of Prosperity</span>
    </span>
  </div>
  <!-- 3D spinning orbit ring — visible on mobile only -->
  <div class="splash-orbit-ring-wrap" aria-hidden="true">
    <div class="splash-orbit-ring" id="splash-orbit-ring"></div>
  </div>
</div>

<!-- Thesis -->
<section id="thesis">
  <div class="thesis-left reveal">
    <div class="section-overline">The Analytical Thesis</div>
    <h2>Where trade, politics, security, and status align — prosperity <em>concentrates.</em></h2>
    <p>The model identifies six distinct historical "Golden Ages" — each with a unique geopolitical logic for converting instability into growth. By mapping today's variables against these proven architectures, we generate actionable strategic playbooks.</p>
    <p>Adjust the four Prosperity Pillars. The engine clusters your inputs to the most mathematically similar era — then populates a strategy drawn from that civilisation's logic.</p>
  </div>
  <div class="thesis-right reveal">
    <div class="pillar-card"><h4>Trade Integration</h4><div class="metric">84.2</div><div class="desc">Economic connectivity and maritime route control</div></div>
    <div class="pillar-card"><h4>Political Stability</h4><div class="metric">71.5</div><div class="desc">Central authority vs. fragmentation index</div></div>
    <div class="pillar-card"><h4>Security Level</h4><div class="metric">92.0</div><div class="desc">Military posture and border vulnerability</div></div>
    <div class="pillar-card"><h4>Social Benefit</h4><div class="metric">68.9</div><div class="desc">Distribution of prosperity gains across layers</div></div>
  </div>
</section>

<!-- Live Feed -->
<section id="livefeed">
  <div class="feed-header">
    <div class="feed-header-left reveal">
      <div class="section-overline"><span class="live-dot"></span> Live Conflict Intelligence</div>
      <h2>U.S.–Iran Theatre Monitor</h2>
    </div>
    <div class="feed-header-right reveal">
      Last updated: <span id="feed-timestamp">—</span><br>
      <span class="feed-source-tag" id="feed-source-tag">GDELT API — LIVE</span>
    </div>
  </div>
  <div class="feed-layout">
    <div class="feed-stream" id="feed-stream"></div>
    <div class="feed-impact-panel reveal">
      <div class="impact-panel-title">Cumulative Pillar Impact</div>
      <div class="impact-meter meter-trade"><div class="impact-meter-header"><span class="impact-meter-label">Trade Integration</span><span class="impact-meter-value" id="feed-trade">0.74</span></div><div class="meter-track"><div class="meter-fill" id="feed-trade-fill" style="width:74%"></div></div></div>
      <div class="impact-meter meter-politics"><div class="impact-meter-header"><span class="impact-meter-label">Political Stability</span><span class="impact-meter-value" id="feed-politics">0.88</span></div><div class="meter-track"><div class="meter-fill" id="feed-politics-fill" style="width:88%"></div></div></div>
      <div class="impact-meter meter-security"><div class="impact-meter-header"><span class="impact-meter-label">Security Level</span><span class="impact-meter-value" id="feed-security">0.92</span></div><div class="meter-track"><div class="meter-fill" id="feed-security-fill" style="width:92%"></div></div></div>
      <div class="impact-meter meter-benefit"><div class="impact-meter-header"><span class="impact-meter-label">Benefit Capture</span><span class="impact-meter-value" id="feed-benefit">0.22</span></div><div class="meter-track"><div class="meter-fill" id="feed-benefit-fill" style="width:22%"></div></div></div>
      <div class="cumulative-shift">
        <h5>Triggered Era Shift</h5>
        <div class="shift-era" id="feed-era-name">Pax Romana</div>
        <div class="shift-era-sub" id="feed-era-sub">High stability corridor — imperial logic active</div>
        <button class="apply-feed-btn" id="apply-to-sim">Copy Feed to Sliders &rarr;</button>
      </div>
    </div>
  </div>
</section>

<!-- Eras -->
<section id="eras">
  <div class="section-overline reveal">The Six Architectures</div>
  <h2 class="reveal">Historical Golden Ages</h2>
  <p class="section-desc reveal">Each era solved the same problem differently: how to organise conflict and hierarchy so that prosperity concentrates at the nexus of power.</p>
  <div class="era-grid">
    {eraCards.map((era) => (
      <div class="era-card reveal" data-era={era.key}>
        <img class="era-card-img" src={era.image} alt={era.title} loading="lazy" decoding="async" />
        <div class="era-artifact" set:html={eraArtifacts[era.key]} />
        <div class="era-figure">
          <img class="era-figure-img" src={era.figure} alt={era.figureName} loading="lazy" decoding="async" />
        </div>
        <div class="era-card-overlay">
          <div class="era-card-date">{era.date}</div>
          <div class="era-card-title">{era.title}</div>
          <div class="era-figure-info">
            <span class="era-figure-name">{era.figureName}</span>
            <span class="era-figure-symbol">{era.symbol}</span>
          </div>
          <div class="era-card-pillars">{era.pillars}</div>
          <div class="era-card-winner">{era.winner}</div>
        </div>
      </div>
    ))}
  </div>
</section>



<!-- Simulation -->
<section id="simulation">
  <div class="sim-header">
    <div class="section-overline reveal">Interactive Simulation Lab</div>
    <h2 class="reveal">The Equilibrium Matrix</h2>
    <p class="reveal">Adjust the four Prosperity Pillars. The engine clusters your configuration to the closest historical architecture and generates a strategic playbook.</p>
  </div>
  <div class="sim-grid">
    <div class="slider-panel reveal">
      <div class="slider-panel-title">Calibration Controls</div>
      <div class="slider-group slider-1"><div class="slider-label"><span>Trade Integration</span><span class="slider-value" id="trade-val">0.74</span></div><input type="range" id="trade" min="0" max="100" value="74"><div class="slider-range"><span>Isolated Markets</span><span>Globalised Routes</span></div></div>
      <div class="slider-group slider-2"><div class="slider-label"><span>Political Stability</span><span class="slider-value" id="politics-val">0.88</span></div><input type="range" id="politics" min="0" max="100" value="88"><div class="slider-range"><span>Fragmented</span><span>Imperial Stability</span></div></div>
      <div class="slider-group slider-3"><div class="slider-label"><span>Security Level</span><span class="slider-value" id="security-val">0.92</span></div><input type="range" id="security" min="0" max="100" value="92"><div class="slider-range"><span>High Vulnerability</span><span>Secure Borders</span></div></div>
      <div class="slider-group slider-4"><div class="slider-label"><span>Benefit Capture</span><span class="slider-value" id="benefit-val">0.22</span></div><input type="range" id="benefit" min="0" max="100" value="22"><div class="slider-range"><span>Broad Middle-Class</span><span>Elite-Concentrated</span></div></div>
      <div class="slider-btns">
        <button class="recalibrate-btn" id="recalibrate">Reset Baseline</button>
        <button class="feed-inject-btn" id="inject-feed">Inject Live Feed</button>
      </div>
    </div>
    <div class="results-panel">
      <div class="result-hero reveal"><div class="overline">Prosperity Score</div><div class="prosperity-score" id="prosperity-score">0.842</div><div class="status" id="system-status">Equilibrium: Nominal</div></div>
      <div class="metrics-row reveal">
        <div class="metric-card"><h5>Benefit Capture Index</h5><div class="val" id="bci-val">0.68</div><div class="change positive" id="bci-change">Elite-Concentrated</div></div>
        <div class="metric-card"><h5>Fragility Rating</h5><div class="val" id="fragility-val">21%</div><div class="change positive" id="fragility-change">Low Risk</div></div>
        <div class="metric-card"><h5>Model Confidence</h5><div class="val" id="conf-val">96.4%</div><div class="change positive">Sigma-5 Validated</div></div>
      </div>
      <div class="era-match reveal">
        <div class="match-overline">Closest Historical Analogue</div>
        <h3 id="matched-era">Pax Romana</h3>
        <div class="era-date" id="matched-date">27 BC – 180 AD · The Antonine Prosperity</div>
        <p id="matched-desc"></p>
        <div class="confidence"><div class="confidence-bar"><div class="confidence-fill" id="confidence-fill" style="width:94%"></div></div><div class="confidence-label" id="confidence-pct">94% Match</div></div>
      </div>
      <div class="playbook-card reveal">
        <div class="playbook-header"><h4 id="playbook-title">U.S.–Iran Strategic Playbook: The Roman Strategy</h4><div class="ai-badge" id="playbook-badge"><span class="ai-dot"></span> Static Baseline</div></div>
        <div class="playbook-grid" id="playbook-grid"></div>
      </div>
    </div>
  </div>
</section>

<!-- Analysis -->
<section id="analysis">
  <div class="analysis-header">
    <div class="section-overline reveal">Quantitative Evidence Base</div>
    <h2 class="reveal">The Numbers Behind the Narratives</h2>
    <p class="reveal">Real economic indicators sourced from Maddison Project, Broadberry & Gupta, World Bank, and Bolt & van Zanden — the empirical backbone of the clustering model.</p>
  </div>

  <div class="analysis-grid">
    <div class="chart-panel reveal">
      <div class="chart-panel-title">Pillar Profile Overlay</div>
      <div class="chart-panel-sub">Your current simulation inputs (gold) vs. the matched era's historical profile (charcoal). Gap = model divergence.</div>
      <canvas id="radar-chart" width="480" height="400"></canvas>
    </div>
    <div class="chart-panel reveal">
      <div class="chart-panel-title">Era Proximity Map (PCA Projection)</div>
      <div class="chart-panel-sub">All 6 eras projected into 2D space via principal component reduction. Your position (gold dot) shows clustering affinity in real-time.</div>
      <canvas id="scatter-chart" width="640" height="540"></canvas>
    </div>
  </div>

  <div class="chart-panel analysis-full reveal">
    <div class="chart-panel-title">Historical Economic Indicators — Source Data</div>
    <div class="chart-panel-sub">Estimated values from Maddison Project Database (2020), Broadberry & Gupta (2006), Bolt & van Zanden (2020). GDP per capita in 1990 International Geary-Khamis dollars.</div>
    <div class="data-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Era</th><th>Period</th><th class="num">GDP/Capita (1990 $)</th><th class="num">Trade % GDP</th><th class="num">Military % GDP</th><th class="num">Gini Coeff.</th><th class="num">Urbanisation %</th><th class="num">Duration (yrs)</th><th class="num">Pop. (millions)</th>
          </tr>
        </thead>
        <tbody>
          {historicalData.map((row) => (
            <tr>
              <td class="era-name">{row.era}</td>
              <td>{row.period}</td>
              <td class="num highlight">{row.gdp}</td>
              <td class="num">{row.trade}</td>
              <td class="num">{row.military}</td>
              <td class="num">{row.gini}</td>
              <td class="num">{row.urban}</td>
              <td class="num">{row.duration}</td>
              <td class="num">{row.pop}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div class="chart-panel analysis-full reveal">
    <div class="chart-panel-title">Prosperity Lifecycle Curves</div>
    <div class="chart-panel-sub">Normalised prosperity trajectory for each era from inception through peak to decline. X-axis = % of era duration. The steeper the descent, the more fragile the model.</div>
    <canvas id="lifecycle-chart" width="1100" height="360"></canvas>
  </div>

  <div class="ai-fragility-panel reveal" id="ai-fragility">
    <div class="ai-briefing-header"><div class="ai-briefing-title"><span class="ai-dot"></span> AI Risk Assessment — Live Configuration</div><div class="ai-badge" id="fragility-badge">Awaiting Simulation</div></div>
    <div class="ai-fragility-body" id="ai-fragility-body">Adjust the simulation sliders above. The AI will generate a bespoke fragility analysis for your exact pillar configuration — identifying specific vulnerabilities, cascading failure points, and mitigation strategies unique to your scenario.</div>
  </div>

  <!-- =========================================================
       REAL DATA CHARTS — World Bank, FRED, Live APIs
       ========================================================= -->
  <div class="analysis-header" style="margin-top:1.5rem;">
    <div class="section-overline reveal">Live Empirical Data</div>
    <h2 class="reveal">Real-World Economic Intelligence</h2>
    <p class="reveal">Six live datasets streamed in real-time via serverless proxy from the Federal Reserve Economic Data (FRED) API — daily frequency, interactive time ranges, zero hardcoded values.</p>
  </div>

  <div class="analysis-grid">
    <div class="chart-panel reveal">
      <div class="chart-panel-title">U.S. Dollar Strength — Trade-Weighted Index</div>
      <div class="chart-panel-sub">Daily trade-weighted U.S. dollar index against major currencies. Rising = stronger dollar. Source: FRED (DTWEXBGS).</div>
      <div class="chart-live-bar">
        <div class="real-chart-status" id="dollar-status">⟳ Fetching live data…</div>
        <div class="chart-latest" id="dollar-latest"></div>
      </div>
      <div class="chart-range-btns" data-chart="dollar">
        <button class="range-btn" data-range="1m">1M</button><button class="range-btn" data-range="3m">3M</button><button class="range-btn" data-range="6m">6M</button><button class="range-btn active" data-range="1y">1Y</button><button class="range-btn" data-range="all">ALL</button>
      </div>
      <canvas id="dollar-chart" width="1100" height="440"></canvas>
    </div>
    <div class="chart-panel reveal">
      <div class="chart-panel-title">Gold Mining Output Price Index — Safe-Haven Demand</div>
      <div class="chart-panel-sub">Producer Price Index for gold ore mining — tracks gold market value at source. Spikes = geopolitical crises or central bank accumulation. Source: FRED (PCU21222122).</div>
      <div class="chart-live-bar">
        <div class="real-chart-status" id="gold-status">⟳ Fetching live data…</div>
        <div class="chart-latest" id="gold-latest"></div>
      </div>
      <div class="chart-range-btns" data-chart="gold">
        <button class="range-btn" data-range="1m">1M</button><button class="range-btn" data-range="3m">3M</button><button class="range-btn" data-range="6m">6M</button><button class="range-btn active" data-range="1y">1Y</button><button class="range-btn" data-range="all">ALL</button>
      </div>
      <canvas id="gold-chart" width="1100" height="440"></canvas>
    </div>
  </div>

  <div class="chart-panel analysis-full reveal">
    <div class="chart-panel-title">Brent Crude Oil — Energy Market Volatility</div>
    <div class="chart-panel-sub">Daily Brent crude prices. Every major price shock correlates with geopolitical events. Source: FRED (DCOILBRENTEU).</div>
    <div class="chart-live-bar">
      <div class="real-chart-status" id="oil-status">⟳ Fetching live data…</div>
      <div class="chart-latest" id="oil-latest"></div>
    </div>
    <div class="chart-range-btns" data-chart="oil">
      <button class="range-btn" data-range="1m">1M</button><button class="range-btn" data-range="3m">3M</button><button class="range-btn" data-range="6m">6M</button><button class="range-btn active" data-range="1y">1Y</button><button class="range-btn" data-range="all">ALL</button>
    </div>
    <canvas id="oil-chart" width="1100" height="420"></canvas>
  </div>

  <div class="analysis-grid">
    <div class="chart-panel reveal">
      <div class="chart-panel-title">Treasury Yield Spread — Recession Risk</div>
