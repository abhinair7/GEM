const feedState = { trade: 0, politics: 0, security: 0, benefit: 0 };
const feedBaseline = { trade: 0.74, politics: 0.88, security: 0.92, benefit: 0.22 };

function classifyArticle(title) {
  const t = title.toLowerCase();
  const impacts = [];
  if (/military|missile|attack|strike|navy|nuclear|weapon|drone|war|bomb|defense|army|irgc|pentagon|troops|deployment/.test(t))
    impacts.push({ pillar: 'security', delta: /peace|ceasefire|withdraw|de-escalat/.test(t) ? 0.04 : -0.06, label: 'Security' });
  if (/sanction|oil|trade|export|import|swift|economic|tariff|crude|energy|pipeline|shipping|cargo|port/.test(t))
    impacts.push({ pillar: 'trade', delta: /lift|ease|remove|resume/.test(t) ? 0.05 : -0.05, label: 'Trade' });
  if (/diplomat|negotiat|talk|summit|alliance|UN|congress|parliament|election|treaty|agreement|minister|ambassador/.test(t))
    impacts.push({ pillar: 'politics', delta: /fail|collapse|reject|withdraw|break/.test(t) ? -0.04 : 0.05, label: 'Politics' });
  if (/protest|inequality|inflation|unemployment|poverty|refugee|humanitarian|civilian|cost.of.living/.test(t))
    impacts.push({ pillar: 'benefit', delta: 0.04, label: 'Benefit' });
  if (impacts.length === 0) {
    if (/iran|tehran|persian/.test(t)) impacts.push({ pillar: 'security', delta: -0.03, label: 'Security' });
    else impacts.push({ pillar: 'politics', delta: -0.02, label: 'Politics' });
  }
  return impacts;
}

function updateFeedMeters() {
  const vals = {
    trade: Math.max(0, Math.min(1, feedBaseline.trade + feedState.trade)),
    politics: Math.max(0, Math.min(1, feedBaseline.politics + feedState.politics)),
    security: Math.max(0, Math.min(1, feedBaseline.security + feedState.security)),
    benefit: Math.max(0, Math.min(1, feedBaseline.benefit + feedState.benefit)),
  };
  ['trade','politics','security','benefit'].forEach(p => {
    document.getElementById('feed-'+p).textContent = vals[p].toFixed(2);
    document.getElementById('feed-'+p+'-fill').style.width = (vals[p]*100)+'%';
  });
  let best = 'romana', bd = Infinity;
  for (const [e,pr] of Object.entries(eraProfiles)) { const d = euclideanDist(vals,pr); if (d<bd){bd=d;best=e;} }
  document.getElementById('feed-era-name').textContent = eraInfo[best].name;
  document.getElementById('feed-era-sub').textContent = eraInfo[best].date;
  highlightEraArtifact(best);
  return vals;
}

function addFeedItem(time, title, desc, impacts, isLive, url) {
  const stream = document.getElementById('feed-stream');
  const item = document.createElement('div');
  item.className = 'feed-item' + (isLive ? ' gdelt-live' : ' active');
  let impHTML = impacts.map(imp => {
    const ds = (imp.delta>0?'+':'')+(imp.delta*100).toFixed(0)+'%';
    return '<div class="impact-chip '+imp.pillar+'">'+imp.label+'</div><div class="impact-delta '+(imp.delta>0?'delta-up':'delta-down')+'">'+ds+'</div>';
  }).join('');
  const linkHTML = url ? '<a href="'+url+'" target="_blank" rel="noopener">Source &rarr;</a>' : '';
  item.innerHTML = '<div class="feed-time">'+time+'</div><div class="feed-content"><h4>'+title+'</h4><p>'+desc+'</p>'+linkHTML+'</div><div class="feed-impact">'+impHTML+'</div>';
  stream.prepend(item);
  requestAnimationFrame(() => { item.style.transition = 'opacity 0.6s, transform 0.6s'; item.style.opacity = '1'; item.style.transform = 'translateX(0)'; });
  impacts.forEach(imp => { feedState[imp.pillar] += imp.delta; });
  updateFeedMeters();
  document.getElementById('feed-timestamp').textContent = time;
}

