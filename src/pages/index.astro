const CEREBRAS_KEY = CEREBRAS_API_KEY || '';
let aiDebounce = null;

// Global store for real chart data (fed into AI prompts dynamically)
const _chartData = { dollar: null, gold: null, oil: null, treasury: null, vix: null, forex: null };
let aiCallQueue = Promise.resolve();

async function callAI(prompt, maxTokens, retries = 3) {
  for (let attempt = 0; attempt < retries; attempt++) {
    const resp = await fetch('https://api.cerebras.ai/v1/chat/completions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + CEREBRAS_KEY },
      body: JSON.stringify({
        model: 'qwen-3-235b-a22b-instruct-2507',
        messages: [{ role: 'system', content: 'You are a senior geopolitical strategist working for the Geopolitical Equilibrium Model (GEM). You produce concise, analytical, and actionable intelligence in a professional editorial tone. Use specific historical references and real-world policy mechanics. Do not use markdown headers — use plain text with line breaks.' }, { role: 'user', content: prompt }],
        max_tokens: maxTokens || 600,
        temperature: 0.7
      })
    });
    if (resp.status === 429 && attempt < retries - 1) {
      const wait = 2000 * Math.pow(2, attempt);
      console.log('Cerebras rate limited, retrying in ' + (wait/1000) + 's (attempt ' + (attempt+1) + ')');
      await new Promise(r => setTimeout(r, wait));
      continue;
    }
    if (!resp.ok) throw new Error('Cerebras API ' + resp.status);
    const data = await resp.json();
    return data.choices[0].message.content;
  }
  throw new Error('Cerebras API rate limit exceeded after retries');
}

function queueAICall(fn) {
  aiCallQueue = aiCallQueue.then(() => fn()).then(
    () => new Promise(r => setTimeout(r, 500)),
    () => new Promise(r => setTimeout(r, 500))
  );
  return aiCallQueue;
}

// AI PLAYBOOK — generates unique strategies per slider config
async function generateAIPlaybook(input, eraName, eraDate) {
  const badge = document.getElementById('playbook-badge');
  badge.textContent = '⟳ Generating…'; badge.className = 'ai-badge generating';
  try {
    const prompt = `The GEM simulation has these Prosperity Pillar values:\n- Trade Integration: ${input.trade.toFixed(2)}\n- Political Stability: ${input.politics.toFixed(2)}\n- Security Level: ${input.security.toFixed(2)}\n- Benefit Capture: ${input.benefit.toFixed(2)}\n\nThe closest historical analogue is: ${eraName} (${eraDate}).\n\nGenerate exactly 3 specific U.S.–Iran strategic moves for this configuration. For each move, provide a bold title (5 words max) and a 2-sentence tactical description referencing real mechanisms (sanctions, naval deployments, diplomatic channels, cyber operations, energy markets, alliance structures).\n\nFormat as:\nSTRATEGY 1: [Title]\n[Description]\n\nSTRATEGY 2: [Title]\n[Description]\n\nSTRATEGY 3: [Title]\n[Description]`;
    const text = await callAI(prompt, 500);
    const strategies = text.split(/STRATEGY \d+:\s*/i).filter(s => s.trim()).map(block => {
      const lines = block.trim().split('\n').filter(l => l.trim());
      const title = lines[0] ? lines[0].replace(/^\*+|\*+$/g, '').trim() : 'Strategic Move';
      const desc = lines.slice(1).join(' ').trim() || block.trim();
      return { title, desc };
    });
    if (strategies.length >= 2) {
      document.getElementById('playbook-grid').innerHTML = strategies.slice(0,3).map(s =>
        '<div class="playbook-item"><h5>' + s.title + '</h5><p>' + s.desc + '</p></div>'
      ).join('');
    }
    badge.textContent = '✦ AI Generated'; badge.className = 'ai-badge active';
  } catch(e) {
    console.log('AI Playbook error:', e.message);
    badge.textContent = 'Static Fallback'; badge.className = 'ai-badge';
  }
}

