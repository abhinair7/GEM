// =========================================================
// LIFECYCLE — STACKED AREA CHART
// =========================================================
function drawLifecycle() {
  const canvas = document.getElementById('lifecycle-chart');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = { top: 30, right: 140, bottom: 50, left: 60 };
  ctx.clearRect(0,0,W,H);
  const curves = {
    romana: { color:'#8b6914', fill:'rgba(139,105,20,0.12)', pts: [[0,0.1],[10,0.3],[25,0.6],[40,0.85],[55,0.95],[70,0.9],[80,0.7],[90,0.4],[100,0.15]], label:'Pax Romana' },
    song: { color:'#2d6e5f', fill:'rgba(45,110,95,0.10)', pts: [[0,0.05],[15,0.25],[30,0.55],[45,0.8],[60,0.92],[70,0.88],[80,0.65],[90,0.3],[100,0.08]], label:'Song Dynasty' },
    renaissance: { color:'#c5a059', fill:'rgba(197,160,89,0.10)', pts: [[0,0.08],[10,0.35],[20,0.65],[35,0.9],[50,0.98],[60,0.85],[75,0.5],[90,0.2],[100,0.05]], label:'Renaissance' },
    twenties: { color:'#c4442d', fill:'rgba(196,68,45,0.10)', pts: [[0,0.15],[15,0.45],[30,0.75],[50,0.95],[60,0.98],[65,0.6],[70,0.2],[80,0.08],[100,0.05]], label:'1920s (Crash)' },
    golden: { color:'#44474e', fill:'rgba(68,71,78,0.10)', pts: [[0,0.1],[10,0.3],[25,0.55],[40,0.75],[55,0.88],[70,0.92],[80,0.85],[90,0.7],[100,0.55]], label:'1950s Golden' },
    nineties: { color:'#1a1c1b', fill:'rgba(26,28,27,0.08)', pts: [[0,0.2],[10,0.4],[25,0.6],[40,0.8],[55,0.92],[65,0.95],[75,0.88],[85,0.72],[100,0.6]], label:'1990s Info Age' },
  };
  const cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom;
  // Grid
  ctx.strokeStyle = 'rgba(0,0,0,0.08)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(W-pad.right, H-pad.bottom); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(pad.left, H-pad.bottom); ctx.lineTo(pad.left, pad.top); ctx.stroke();
  ctx.font = '400 9px Inter'; ctx.fillStyle = '#a3a8a0'; ctx.textAlign = 'right';
  for (let v = 0; v <= 1; v += 0.25) {
    const y = H - pad.bottom - v * ch;
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W-pad.right, y); ctx.strokeStyle = 'rgba(0,0,0,0.03)'; ctx.stroke();
    ctx.fillText((v*100).toFixed(0)+'%', pad.left-8, y+3);
  }
  ctx.textAlign = 'center'; ctx.fillStyle = '#a3a8a0';
  ['INCEPTION','25%','PEAK','75%','DECLINE'].forEach((l,i) => { ctx.fillText(l, pad.left + (i/4)*cw, H-pad.bottom+20); });
  ctx.font = '500 9px Inter'; ctx.fillStyle = '#74796e'; ctx.fillText('% OF ERA DURATION', (pad.left + W - pad.right)/2, H-8);
  // Draw filled areas + lines
  function interpY(pts, xPct) {
    for (let i = 0; i < pts.length - 1; i++) {
      if (xPct >= pts[i][0] && xPct <= pts[i+1][0]) {
        const t = (xPct - pts[i][0]) / (pts[i+1][0] - pts[i][0]);
        return pts[i][1] + t * (pts[i+1][1] - pts[i][1]);
      }
    }
    return pts[pts.length-1][1];
  }
  Object.values(curves).forEach(era => {
    // Filled area
    ctx.beginPath();
    for (let pct = 0; pct <= 100; pct += 0.5) {
      const x = pad.left + (pct/100)*cw;
      const y = H - pad.bottom - interpY(era.pts, pct)*ch;
      pct === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.lineTo(pad.left + cw, H - pad.bottom);
    ctx.lineTo(pad.left, H - pad.bottom);
    ctx.closePath();
    ctx.fillStyle = era.fill; ctx.fill();
    // Stroke line
    ctx.beginPath();
    for (let pct = 0; pct <= 100; pct += 0.5) {
      const x = pad.left + (pct/100)*cw;
      const y = H - pad.bottom - interpY(era.pts, pct)*ch;
      pct === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.strokeStyle = era.color; ctx.lineWidth = 2; ctx.stroke();
    // Peak dot
    const peak = era.pts.reduce((a,b) => b[1] > a[1] ? b : a);
    const px = pad.left + (peak[0]/100)*cw, py = H - pad.bottom - peak[1]*ch;
    ctx.beginPath(); ctx.arc(px, py, 4, 0, Math.PI*2);
    ctx.fillStyle = era.color; ctx.fill();
  });
  // Legend on right
  let ly = pad.top + 10;
  Object.values(curves).forEach(era => {
    ctx.fillStyle = era.color; ctx.fillRect(W-pad.right+16, ly, 12, 12);
    ctx.fillStyle = era.fill; ctx.fillRect(W-pad.right+16, ly, 12, 12);
    ctx.strokeStyle = era.color; ctx.lineWidth = 1.5; ctx.strokeRect(W-pad.right+16, ly, 12, 12);
    ctx.font = '500 9px Inter'; ctx.fillStyle = '#44474e'; ctx.textAlign = 'left';
    ctx.fillText(era.label, W-pad.right+34, ly+10);
    ly += 22;
  });
}

